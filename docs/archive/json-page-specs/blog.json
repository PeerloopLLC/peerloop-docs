{
  "metadata": {
    "title": "Blog",
    "code": "BLOG",
    "route": "/blog",
    "astroFile": "src/pages/blog/index.astro",
    "access": "Public",
    "priority": "P2",
    "tsxComponents": [],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/BLOG/BLOG.md",
      "spec": "docs/pagespecs/BLOG.md"
    }
  },
  "purpose": "Content marketing and SEO. Share educational content, platform updates, teaching tips, and success stories to attract organic traffic and engage users.",
  "connections": {
    "incoming": [
      {
        "source": "(External)",
        "sourceRoute": "",
        "trigger": "Search engines, social media",
        "notes": "Organic traffic entry point"
      },
      {
        "source": "HOME",
        "sourceRoute": "/",
        "trigger": "Footer 'Blog' link",
        "notes": "From homepage"
      }
    ],
    "outgoing": [
      {
        "target": "BPOS",
        "targetRoute": "/blog/[slug]",
        "trigger": "Article click",
        "notes": "Individual post"
      },
      {
        "target": "CBRO",
        "targetRoute": "/courses",
        "trigger": "Related course links",
        "notes": "Course discovery from content"
      },
      {
        "target": "SGUP",
        "targetRoute": "/signup",
        "trigger": "Newsletter signup or CTA",
        "notes": "Conversion from content"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "blog_posts",
      "fields_used": "id, slug, title, excerpt, featured_image, author_id, category, tags, published_at, read_time",
      "purpose": "Display blog post listings"
    },
    {
      "entity": "blog_categories",
      "fields_used": "id, name, slug, description",
      "purpose": "Category filters"
    },
    {
      "entity": "users (authors)",
      "fields_used": "name, avatar",
      "purpose": "Author attribution"
    }
  ],
  "sections": [
    {
      "title": "Hero",
      "items": [
        "Headline: \"Peerloop Blog\"",
        "Subheadline: \"Tips, stories, and insights for learners and teachers\"",
        "Newsletter signup CTA"
      ]
    },
    {
      "title": "Featured Post",
      "items": [
        "Large featured article card",
        "Hero image, title, excerpt",
        "Author, date, read time"
      ]
    },
    {
      "title": "Category Filters",
      "items": [
        "All Posts",
        "Learning Tips",
        "Teaching Tips",
        "Success Stories",
        "Product Updates",
        "Industry Insights"
      ]
    },
    {
      "title": "Post Grid",
      "items": [
        "Article cards with thumbnails",
        "Title, excerpt, category tag",
        "Author avatar, date, read time"
      ]
    },
    {
      "title": "Pagination",
      "items": [
        "Load more or page numbers",
        "10-12 posts per page"
      ]
