      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"Community\" / \"Feed\" link",
        "notes": "Global navigation"
      },
      {
        "source": "SDSH",
        "sourceRoute": "/dashboard/learning",
        "trigger": "\"Community\" quick action",
        "notes": "From dashboard"
      },
      {
        "source": "NOTF",
        "sourceRoute": "/notifications",
        "trigger": "Notification about post",
        "notes": "Direct to specific post"
      },
      {
        "source": "(External)",
        "sourceRoute": "",
        "trigger": "Direct URL",
        "notes": "`/community`"
      }
    ],
    "outgoing": [
      {
        "target": "PROF",
        "targetRoute": "/profile",
        "trigger": "Author name/avatar click",
        "notes": "View poster's profile"
      },
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course mention click",
        "notes": "View mentioned course"
      },
      {
        "target": "CPRO",
        "targetRoute": "/creators/[handle]",
        "trigger": "Creator mention click",
        "notes": "View creator profile"
      },
      {
        "target": "(Post Detail)",
        "targetRoute": "",
        "trigger": "Post click",
        "notes": "Expand post with replies"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "posts",
      "fields_used": "id, author_id, content, post_type, created_at, is_pinned",
      "purpose": "Feed content"
    },
    {
      "entity": "users",
      "fields_used": "id, name, avatar, handle",
      "purpose": "Author display"
    },
    {
      "entity": "follows",
      "fields_used": "follower_id, followed_id",
      "purpose": "Who user follows"
    },
    {
      "entity": "course_follows",
      "fields_used": "user_id, course_id",
      "purpose": "Course subscriptions"
    },
    {
      "entity": "post_interactions",
      "fields_used": "post_id, type, count",
      "purpose": "Like/bookmark counts"
    },
    {
      "entity": "(Stream API)",
      "fields_used": "feed data",
      "purpose": "External feed service"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Page title: \"Community\" or \"Your Feed\"",
        "Feed type tabs (optional): \"For You\" / \"Following\" / \"Courses\""
      ]
    },
    {
      "title": "Post Composer",
      "items": [
        "Avatar of current user",
        "Text input: \"What's on your mind?\"",
        "Post type selector (optional):",
        "Media attachment (future)",
        "\"Post\" button"
      ]
    },
    {
      "title": "Feed",
      "items": [
        "Infinite scroll of posts",
        "Each post shows:",
        "Pinned posts at top (from moderators)"
      ]
    },
    {
      "title": "Sidebar (Desktop)",
      "items": [
        "**Suggested Follows:**",
        "**Trending Topics:**",
        "**Upcoming Sessions:**",
        "**Who to Follow:**"
      ]
    },
    {
      "title": "Empty State",
      "items": [
        "New user with no follows: \"Follow some creators to see posts here\"",
        "Suggestions for who to follow"
      ]
    }
