{
  "metadata": {
    "title": "Session Room",
    "code": "SROM",
    "route": "/session/[id]",
    "astroFile": "src/pages/session/[id].astro",
    "access": "Authenticated",
    "priority": "P0",
    "testScript": "scripts/page-tests/test-SROM.sh",
    "tsxComponents": [
      "src/components/booking/SessionRoom.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/SROM/SROM.md",
      "spec": "docs/pagespecs/session/SROM.md"
    }
  },
  "purpose": "Video conferencing interface for 1-on-1 tutoring sessions between students and Student-Teachers, powered by VideoProvider (BBB or PlugNmeet).",
  "connections": {
    "incoming": [
      {
        "source": "SDSH",
        "sourceRoute": "/dashboard/learning",
        "trigger": "\"Join Session\" button",
        "notes": "Student joining"
      },
      {
        "source": "TDSH",
        "sourceRoute": "/dashboard/teaching",
        "trigger": "\"Join Session\" button",
        "notes": "ST joining"
      },
      {
        "source": "NOTF",
        "sourceRoute": "/notifications",
        "trigger": "Session reminder notification",
        "notes": "Direct join"
      },
      {
        "source": "(Email)",
        "sourceRoute": "",
        "trigger": "Email reminder link",
        "notes": "Direct join"
      }
    ],
    "outgoing": [
      {
        "target": "SDSH",
        "targetRoute": "/dashboard/learning",
        "trigger": "\"Back to Dashboard\" / session ends (Student)",
        "notes": "Return to dashboard"
      },
      {
        "target": "TDSH",
        "targetRoute": "/dashboard/teaching",
        "trigger": "\"Back to Dashboard\" / session ends (ST)",
        "notes": "Return to dashboard"
      },
      {
        "target": "CCNT",
        "targetRoute": "/courses/[slug]/learn",
        "trigger": "\"Back to Course\"",
        "notes": "Return to course content"
      },
      {
        "target": "(Feedback)",
        "targetRoute": "",
        "trigger": "Session ends",
        "notes": "Post-session feedback modal"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "sessions",
      "fields_used": "id, scheduled_start, scheduled_end, bbb_meeting_url, status",
      "purpose": "Session info"
    },
    {
      "entity": "users (student)",
      "fields_used": "name, avatar",
      "purpose": "Participant display"
    },
    {
      "entity": "users (teacher)",
      "fields_used": "name, avatar",
      "purpose": "Participant display"
    },
    {
      "entity": "courses",
      "fields_used": "title",
      "purpose": "Context display"
    },
    {
      "entity": "enrollments",
      "fields_used": "course_id",
      "purpose": "Course context"
    },
    {
      "entity": "session_resources",
      "fields_used": "id, name, type, r2_key, duration_seconds",
      "purpose": "Session resources"
    }
  ],
  "sections": [
    {
      "title": "Pre-Join Screen (Before Video Starts)",
      "items": [
        "**Session Info:**",
        "**Device Check:**",
        "**Ready Actions:**",
        "**Tips:**"
      ]
    },
    {
      "title": "Video Room (Main Session)",
      "items": [
        "**Video Area:**",
        "**Controls Bar:**",
        "**Side Panel (Optional):**",
        "**Session Timer:**"
      ]
    },
    {
      "title": "Session Header",
      "items": [
        "Course title",
        "Participant name",
        "Session status indicator"
      ]
    },
    {
      "title": "Post-Session Screen",
      "items": [
        "\"Session Ended\"",
        "**Quick Feedback:**",
        "**Actions:**",
        "**Session Resources:**",
        "**Upload Resources (ST only):**"
      ]
    }
  ],
  "userStories": [
    "US-S042: Join scheduled session",
    "US-S043: Participate in video session",
    "US-V001: Access video conferencing",
    "US-V005: Access session recordings (if enabled)",
    "US-V006: Rate session after completion",
    "US-T007: ST conducts teaching session"
  ],
  "statesVariations": [
    {
      "state": "Early",
      "description": "Session not yet joinable (>15 min before)"
    },
    {
      "state": "Joinable",
      "description": "Within join window, pre-join screen"
    },
    {
      "state": "In Progress",
      "description": "Active video session"
    },
    {
      "state": "Waiting",
      "description": "One participant waiting for other"
    },
    {
      "state": "Ended",
      "description": "Post-session feedback screen"
    },
    {
      "state": "No Show",
      "description": "Other participant didn't join"
    },
    {
      "state": "Technical Issues",
      "description": "Connection problems, retry options"
    }
  ],
  "mobileConsiderations": [
    "Full-screen video by default",
    "Controls at bottom, auto-hide",
    "Portrait: stacked videos",
    "Landscape: side-by-side",
    "Minimize to picture-in-picture"
  ],
  "errorHandling": [
    {
      "error": "Session not found",
      "display": "\"Session not found. Check your dashboard.\""
    },
    {
      "error": "Not authorized",
      "display": "\"You're not part of this session.\""
    },
    {
      "error": "Session expired",
      "display": "\"This session has ended.\""
    },
    {
      "error": "Connection failed",
      "display": "\"Unable to connect. [Retry]\""
    },
    {
      "error": "Camera/mic denied",
      "display": "\"Please allow camera/microphone access.\""
    },
    {
      "error": "Video provider error",
      "display": "\"Video service unavailable. Try again.\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "session_id, user_role"
    },
    {
      "event": "`session_joined`",
      "trigger": "Entered video room",
      "data": "session_id, time_before_start"
    },
    {
      "event": "`session_started`",
      "trigger": "Both participants present",
      "data": "session_id"
    },
    {
      "event": "`session_ended`",
      "trigger": "Session concluded",
      "data": "session_id, duration"
    },
    {
      "event": "`feedback_submitted`",
      "trigger": "Rating submitted",
      "data": "session_id, rating"
    },
    {
      "event": "`tech_issue`",
      "trigger": "Connection problem",
      "data": "error_type"
    }
  ],
  "notes": [
    "**VideoProvider:** PlugNmeet (selected per `assets/video-platform-decisions.md`)",
    "CD-007: 1-on-1 optimized, P2P when possible",
    "Recording storage: PlugNmeet → R2 replication",
    "Session reminders: 24h, 1h, 15min before (via Resend)",
    "Consider \"reschedule\" option from pre-join if issues",
    "Accessibility: Keyboard navigation, screen reader support for controls"
  ],
  "testCoverage": {
    "pageTest": {
      "file": "tests/pages/session/[id].test.tsx",
      "exists": false
    },
    "componentTest": {
      "file": "tests/components/booking/SessionRoom.test.tsx",
      "exists": true
    },
    "apiTests": [
      {
        "endpoint": "(covered by join.test.ts)",
        "testFile": "tests/api/sessions/[id]/join.test.ts",
        "tested": true
      },
      {
        "endpoint": "(covered by rating.test.ts)",
        "testFile": "tests/api/sessions/[id]/rating.test.ts",
        "tested": true
      },
      {
        "endpoint": "POST /api/sessions/[id]/join",
        "tested": false
      },
      {
        "endpoint": "POST /api/sessions/[id]/rating",
        "tested": false
      }
    ],
    "summary": {
      "pageTest": false,
      "componentTest": true,
      "apiCoverage": "2/4",
      "readyToWork": false
    }
  },
  "plannedApiCalls": []
}
