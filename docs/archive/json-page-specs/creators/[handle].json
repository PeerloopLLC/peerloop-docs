{
  "metadata": {
    "title": "Creator Profile",
    "code": "CPRO",
    "route": "/creators/:handle",
    "astroFile": "src/pages/creators/[handle].astro",
    "access": "Public",
    "priority": "P0",
    "testScript": "scripts/page-tests/test-CPRO.sh",
    "tsxComponents": [
      "src/components/creators/profiles/CreatorProfile.tsx",
      "src/components/context-actions/index.ts"
    ],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/CPRO/CPRO.md",
      "spec": "docs/pagespecs/creators/CPRO.md"
    }
  },
  "purpose": "Display comprehensive creator information including qualifications, expertise, courses, and teaching philosophy to build trust and drive course enrollment.",
  "connections": {
    "incoming": [
      {
        "source": "CRLS",
        "sourceRoute": "/creators",
        "trigger": "Creator card click",
        "notes": "From creator listing"
      },
      {
        "source": "CDET",
        "sourceRoute": "/courses/[slug]",
        "trigger": "Creator name/avatar click",
        "notes": "From course detail"
      },
      {
        "source": "CBRO",
        "sourceRoute": "/courses",
        "trigger": "Creator name on course card",
        "notes": "From browse results"
      },
      {
        "source": "SDSH",
        "sourceRoute": "/dashboard/learning",
        "trigger": "Creator link on enrolled course",
        "notes": "Student viewing creator"
      },
      {
        "source": "(External)",
        "trigger": "Direct URL, shared link",
        "notes": "/@brian or /creators/brian"
      }
    ],
    "outgoing": [
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course card click",
        "notes": "View specific course"
      },
      {
        "target": "CBRO",
        "targetRoute": "/courses",
        "trigger": "\"View All Courses\"",
        "notes": "Filtered by this creator"
      },
      {
        "target": "SGUP",
        "targetRoute": "/signup",
        "trigger": "Follow button (logged out)",
        "notes": "Redirect to signup"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "users",
      "fields_used": "id, name, handle, avatar, title, bio, website, teaching_philosophy",
      "purpose": "Profile display"
    },
    {
      "entity": "user_qualifications",
      "fields_used": "sentence, display_order",
      "purpose": "Credentials section"
    },
    {
      "entity": "user_expertise",
      "fields_used": "tag",
      "purpose": "Expertise tags"
    },
    {
      "entity": "user_stats",
      "fields_used": "students_taught, courses_created, average_rating, total_reviews",
      "purpose": "Stats bar"
    },
    {
      "entity": "courses",
      "fields_used": "id, title, slug, thumbnail, price, rating, level",
      "purpose": "Courses list"
    },
    {
      "entity": "follows",
      "fields_used": "count where followed_id = creator",
      "purpose": "Follower count"
    }
  ],
