  "sections": [
    {
      "title": "Profile Header",
      "items": [
        "Avatar: Large circular image",
        "Name: Display name",
        "Handle: @handle",
        "Title: Professional title",
        "Follow button: Follows creator (logged in) or prompts signup",
        "Website link: External link icon"
