  "plannedApiCalls": [
    {
      "endpoint": "GET /api/users?role=creator",
      "when": "Page load",
      "purpose": "Creator list with stats",
      "notes": "Response shape matches UserCardData interface (camelCase). Returns: id, name, handle, avatarUrl, title, bioShort, location, website, linkedinUrl, twitterUrl, youtubeUrl, isCreator, isStudentTeacher, isPrivate, stats (studentsTaught, coursesCreated, averageRating, totalReviews). Private profiles return isPrivate:true with minimal data."
    },
    {
      "endpoint": "GET /api/users?role=creator&sort=rating",
      "when": "Sort by rating",
      "purpose": "Sort options: recent (default), rating, studentsTaught"
    },
