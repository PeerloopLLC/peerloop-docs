  "plannedApiCalls": [
    {
      "endpoint": "GET /api/users?role=student_teacher",
      "when": "Page load",
      "purpose": "All active Student-Teachers with stats",
      "notes": "Response shape matches UserCardData interface (camelCase). Returns: id, name, handle, avatarUrl, title, bioShort, isCreator, isStudentTeacher, stats. Private profiles return isPrivate:true with minimal data."
    },
    {
      "endpoint": "GET /api/users?role=student_teacher&courseId={courseId}",
      "when": "Filter by course",
      "purpose": "STs certified for a specific course"
    },
    {
      "endpoint": "GET /api/users?role=student_teacher&sort=rating",
      "when": "Sort",
      "purpose": "Sort options: recent (default), rating, studentsTaught"
    },
    {
      "endpoint": "GET /api/courses",
      "when": "Page load",
      "purpose": "Course filter dropdown options"
    }
  ],
