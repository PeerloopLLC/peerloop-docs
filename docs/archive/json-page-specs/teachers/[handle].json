{
  "metadata": {
    "title": "Student-Teacher Profile",
    "code": "STPR",
    "route": "/teachers/[handle]",
    "astroFile": "src/pages/teachers/[handle].astro",
    "access": "Public",
    "priority": "P0",
    "testScript": "scripts/page-tests/test-STPR.sh",
    "tsxComponents": [
      "src/components/student-teachers/profiles/STProfile.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/STPR/STPR.md",
      "spec": "docs/pagespecs/teachers/STPR.md"
    }
  },
  "purpose": "Display Student-Teacher's credentials, teaching availability, courses they're certified to teach, and enable session booking.",
  "connections": {
    "incoming": [
      {
        "source": "STDR",
        "sourceRoute": "/teachers",
        "trigger": "ST card click",
        "notes": "From ST directory"
      },
      {
        "source": "CDET",
        "sourceRoute": "/courses/[slug]",
        "trigger": "ST name in course's ST list",
        "notes": "From course detail"
      },
      {
        "source": "SBOK",
        "sourceRoute": "/courses/[slug]/book",
        "trigger": "ST info link",
        "notes": "While booking"
      },
      {
        "source": "SDSH",
        "sourceRoute": "/dashboard/learning",
        "trigger": "\"Your Teacher\" link",
        "notes": "Student viewing assigned ST"
      },
      {
        "source": "TDSH",
        "sourceRoute": "/dashboard/teaching",
        "trigger": "Own profile link",
        "notes": "ST viewing their public profile"
      },
      {
        "source": "(External)",
        "sourceRoute": "",
        "trigger": "Direct URL",
        "notes": "`/@sarah`"
      }
    ],
    "outgoing": [
      {
        "target": "SBOK",
        "targetRoute": "/courses/[slug]/book",
        "trigger": "\"Book Session\" CTA",
        "notes": "Pre-select this ST"
      },
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course card click",
        "notes": "View course they teach"
      },
      {
        "target": "MSGS",
        "targetRoute": "/messages",
        "trigger": "\"Message\" button",
        "notes": "DM the ST (if allowed)"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "users",
      "fields_used": "id, name, handle, avatar, title, bio, privacy_public",
      "purpose": "Profile info"
    },
    {
      "entity": "student_teachers",
      "fields_used": "course_id, students_taught, certified_date",
      "purpose": "ST credentials"
    },
    {
      "entity": "certificates",
      "fields_used": "type, issued_at",
      "purpose": "Completion/mastery certs"
    },
    {
      "entity": "courses",
      "fields_used": "id, title, slug, thumbnail",
      "purpose": "Courses they teach"
    },
    {
      "entity": "availability",
      "fields_used": "day_of_week, start_time, end_time, timezone",
      "purpose": "Availability calendar"
    },
    {
      "entity": "user_stats",
      "fields_used": "average_rating, total_reviews",
      "purpose": "Teaching stats"
    },
    {
      "entity": "sessions",
      "fields_used": "count",
      "purpose": "Sessions conducted"
    }
  ],
  "sections": [
    {
      "title": "Profile Header",
      "items": [
        "Avatar (with ST badge overlay)",
        "Name",
        "Handle: @handle",
        "Title/bio",
        "**Teaching Badge:** Visual indicator of ST status",
        "Stats row: X students taught, Y sessions, Z rating"
      ]
    },
    {
      "title": "Availability Section",
      "items": [
        "**\"Available to Help\" indicator** (green/gray)",
        "Weekly availability grid:",
        "Timezone display",
        "\"Book a Session\" CTA → SBOK"
      ]
    },
    {
      "title": "Courses I Teach",
      "items": [
        "Cards for each course they're certified to teach",
        "For each:"
      ]
    },
    {
      "title": "Certifications",
      "items": [
        "List of earned certificates:",
        "Issue dates"
      ]
    },
    {
      "title": "Reviews/Testimonials (if available)",
      "items": [
        "Recent reviews from students they've taught",
        "Average rating"
      ]
    },
    {
      "title": "Bio/About",
      "items": [
        "Extended bio text",
        "Teaching philosophy (if set)"
      ]
    }
  ],
  "userStories": [
    "US-G009: View ST profile as visitor",
    "US-T003: ST has public profile showing credentials",
    "US-T004: ST displays availability",
    "US-T020: ST can toggle public visibility",
    "US-T021: ST shows courses certified to teach",
    "US-T022: ST shows students taught count"
  ],
  "statesVariations": [
    {
      "state": "Visitor",
      "description": "View only, booking prompts signup"
    },
    {
      "state": "Logged In (Not Enrolled)",
      "description": "\"Enroll first\" for booking"
    },
    {
      "state": "Logged In (Enrolled in matching course)",
      "description": "\"Book Session\" active"
    },
    {
      "state": "Own Profile (ST viewing self)",
      "description": "\"Edit Profile\" link, no booking CTA"
    },
    {
      "state": "Private Profile",
      "description": "\"This profile is private\" (if privacy_public = false)"
    }
  ],
  "mobileConsiderations": [
    "Header stacks vertically",
    "Availability becomes scrollable horizontal calendar",
    "Course cards single column",
    "Sticky \"Book Session\" button"
  ],
  "errorHandling": [
    {
      "error": "Profile not found",
      "display": "404 page"
    },
    {
      "error": "Profile private",
      "display": "\"This profile is private\""
    },
    {
      "error": "No availability",
      "display": "\"No available slots. Check back later.\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "st_id, source"
    },
    {
      "event": "`book_click`",
      "trigger": "Book session clicked",
      "data": "st_id, course_id"
    },
    {
      "event": "`course_click`",
      "trigger": "Course card clicked",
      "data": "course_id"
    },
    {
      "event": "`availability_viewed`",
      "trigger": "Availability section viewed/expanded",
      "data": "st_id"
    }
  ],
  "notes": [
    "ST profile is an extension of regular user profile (PROF)",
    "Badge/indicator distinguishes ST from regular student",
    "CD-018: Student profile system ($14K-19K estimate includes this)",
    "Consider merging with PROF using role-aware sections"
  ],
  "testCoverage": {
    "pageTest": {
      "file": "tests/pages/teachers/[handle].test.tsx",
      "exists": false
    },
    "componentTest": {
      "file": "tests/pages/teachers/STProfile.test.tsx",
      "exists": true
    },
    "apiTests": [],
    "summary": {
      "pageTest": false,
      "componentTest": true,
      "apiCoverage": "0/0",
      "readyToWork": true
    }
  },
  "plannedApiCalls": [
    {
      "endpoint": "`GET /api/users/:handle`",
      "when": "Page load",
      "purpose": "Profile data"
    },
    {
      "endpoint": "`GET /api/users/:handle/st-info`",
      "when": "Page load (if ST)",
      "purpose": "ST-specific data"
    },
    {
      "endpoint": "`GET /api/users/:handle/availability`",
      "when": "Page load",
      "purpose": "Availability calendar"
    },
    {
      "endpoint": "`GET /api/users/:handle/reviews`",
      "when": "Page load",
      "purpose": "Teaching reviews"
    },
    {
      "endpoint": "`GET /api/users/me/enrollments`",
      "when": "Page load (auth)",
      "purpose": "Check if can book"
    }
  ]
}
