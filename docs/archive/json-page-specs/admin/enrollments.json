        "trigger": "\"Enrollments\" nav item",
        "notes": "Admin sidebar"
      },
      {
        "source": "AUSR",
        "sourceRoute": "/admin/users",
        "trigger": "\"View Enrollments\" on user",
        "notes": "Filtered to user"
      },
      {
        "source": "ACRS",
        "sourceRoute": "/admin/courses",
        "trigger": "\"View Enrollments\" on course",
        "notes": "Filtered to course"
      }
