  "purpose": "Manage platform payouts - process pending payouts to STs and Creators, view transaction history, and handle payment issues.",
  "connections": {
    "incoming": [
      {
        "source": "ADMN",
        "sourceRoute": "/admin",
        "trigger": "\"Payouts\" nav item",
        "notes": "Admin sidebar"
      },
      {
        "source": "AUSR",
        "sourceRoute": "/admin/users",
        "trigger": "\"View Payouts\" on user",
        "notes": "Filtered to user (API supports, UI doesn't use yet)"
      }
    ],
    "outgoing": [
      {
        "target": "AUSR",
        "targetRoute": "/admin/users",
        "trigger": "Recipient name click",
        "notes": "Not yet linked"
      },
      {
        "target": "AENR",
        "targetRoute": "/admin/enrollments",
        "trigger": "\"View Enrollment\"",
        "notes": "Not yet linked"
      },
      {
        "target": "(Stripe)",
        "targetRoute": "https://dashboard.stripe.com",
        "trigger": "\"View in Stripe\"",
        "notes": "External link - active"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "payouts",
      "fields_used": "id, recipient_id, recipient_type, amount_cents, stripe_transfer_id, status, approved_by, approved_at, paid_at, failure_reason, created_at",
      "purpose": "Payout records"
    },
    {
      "entity": "payment_splits",
      "fields_used": "id, transaction_id, enrollment_id, recipient_id, recipient_type, amount_cents, percentage, stripe_transfer_id, status, payout_id, created_at, paid_at",
      "purpose": "Revenue splits that make up payouts"
    },
    {
      "entity": "transactions",
      "fields_used": "id, enrollment_id, amount_cents, stripe_payment_intent_id, status, created_at",
      "purpose": "Source transactions for splits"
    },
    {
      "entity": "users",
      "fields_used": "id, name, email, avatar_url, handle, stripe_account_id, stripe_account_status, stripe_payouts_enabled",
      "purpose": "Recipient info and Stripe Connect status"
    },
    {
      "entity": "courses",
      "fields_used": "id, title",
      "purpose": "Course context for splits"
    },
    {
      "entity": "enrollments",
      "fields_used": "id, student_id, course_id",
      "purpose": "Enrollment context for splits"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Screen title: \"Payout Management\"",
        "Subtitle: \"Process payments to Student-Teachers and Creators\"",
        "\"Process All Pending\" button (shows when pending_count > 0)"
      ]
    },
    {
      "title": "Summary Cards (4 columns)",
      "items": [
        "**Pending Payouts** - Total $ of created but unprocessed payouts + recipient count",
        "**Processing** - Currently in transit to Stripe (yellow)",
        "**Paid This Month** - Month-to-date total (green)",
        "**Paid All Time** - Lifetime total (indigo)"
      ]
    },
    {
      "title": "Status Tabs",
      "items": [
        "**Pending** - Created payouts awaiting processing (badge shows count)",
        "**Processing** - Sent to Stripe, awaiting confirmation",
        "**Completed** - Successfully paid",
        "**Failed** - Failed payouts with retry option (badge shows count)"
      ]
    },
    {
      "title": "Pending Tab - Grouped View",
      "items": [
        "Recipients grouped by user with collapsible sections",
        "Avatar/initial + name, Type (Student-Teacher / Creator) + handle",
        "Pending balance (large, bold), Transaction count",
        "\"Stripe Ready\" or \"Stripe Pending\" badge",
        "\"Create Payout\" button (disabled if Stripe not ready)",
        "Expand/collapse chevron"
      ]
    },
    {
      "title": "Expanded Details Table",
      "items": [
        "Date - Transaction date",
        "Course - Course title",
        "Student - Student name",
        "Split Type - Type + percentage",
        "Amount - Split amount"
      ]
    },
    {
      "title": "Other Tabs - Table View",
      "items": [
        "Columns: Recipient (avatar + name + type), Amount, Splits count, Status badge, Created date, Paid date, Actions menu",
        "Sortable by created_at and amount_cents",
        "Row click opens detail panel"
      ]
    },
    {
      "title": "Payout Detail Panel",
      "items": [
        "**Recipient Section**: Avatar + name + email, Type, Stripe Account ID, Payouts Enabled (Yes/No)",
        "**Status Section**: Current status badge, Amount, Created date, Approved by/at, Paid at, Stripe Transfer ID, Failure reason",
        "**Included Transactions**: Scrollable list of splits with course title, amount, student name, date, split type + percentage",
        "**Footer Actions**: Process Payout (pending), Cancel (pending), Retry (failed), View in Stripe"
      ]
    }
  ],
  "userStories": [
    "US-A045",
    "US-A046",
    "US-A047",
    "US-A048"
  ],
  "statesVariations": [
    {
      "state": "Pending Tab - Empty",
      "description": "Success icon, 'All payment splits have been processed'"
    },
    {
      "state": "Pending Tab - With Recipients",
      "description": "Grouped cards, some expanded to show splits"
    },
    {
      "state": "Processing Tab",
      "description": "Table of in-transit payouts"
    },
    {
      "state": "Completed Tab",
      "description": "History table with all successful payouts"
    },
    {
      "state": "Failed Tab",
      "description": "Table with retry actions available"
    },
    {
      "state": "Detail Panel Open",
      "description": "Slide-in panel with payout info and splits"
    },
    {
      "state": "Batch Processing",
      "description": "Process All button shows spinner, disabled during operation"
    }
  ],
  "mobileConsiderations": [
    "Stats cards should stack 2x2 on small screens",
    "Tabs may need horizontal scroll on narrow screens",
    "Detail panel should be full-width on mobile",
    "Grouped recipient view should remain usable on small screens"
  ],
  "errorHandling": [
    {
      "error": "API load fails",
      "display": "Red error banner with Retry button"
    },
    {
      "error": "Stripe transfer fails",
      "display": "Alert with error, payout moves to Failed tab"
    },
    {
      "error": "No Stripe account",
      "display": "Create Payout disabled, \"Stripe Pending\" badge"
    },
    {
      "error": "Below minimum ($50)",
      "display": "Alert showing threshold not met"
    },
    {
      "error": "Batch partial failure",
      "display": "Summary alert (X succeeded, Y failed)"
    }
  ],
  "analyticsEvents": [
    {
      "event": "admin_payout_viewed",
      "trigger": "Page load",
      "data": "tab (pending/processing/completed/failed)"
    },
    {
      "event": "admin_payout_processed",
      "trigger": "Single payout processed",
      "data": "payout_id, amount_cents, recipient_type"
    },
    {
      "event": "admin_payout_batch_processed",
      "trigger": "Batch process completed",
      "data": "count, total_amount_cents, success_count, fail_count"
    },
    {
      "event": "admin_payout_cancelled",
      "trigger": "Pending payout cancelled",
      "data": "payout_id"
    },
    {
      "event": "admin_payout_retried",
      "trigger": "Failed payout reset for retry",
      "data": "payout_id, previous_failure_reason"
    }
  ],
  "notes": [
    "CD-020: Semi-automated payouts (admin approves, Stripe transfers)",
    "Stripe Connect Express accounts for marketplace payouts",
    "Minimum payout threshold: $50 (enforced in POST /api/admin/payouts)",
    "All transfers tagged with transfer_group for reconciliation",
    "Admin can only process existing splits, cannot modify amounts",
    "Failed payouts retain failure_reason from Stripe",
    "Tax documentation: 1099 thresholds should be tracked (future)"
  ],
