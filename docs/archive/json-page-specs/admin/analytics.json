{
  "metadata": {
    "title": "Admin Analytics",
    "code": "AANA",
    "route": "/admin/analytics",
    "astroFile": "src/pages/admin/analytics.astro",
    "access": "Admin",
    "priority": "P1",
    "testScript": "scripts/page-tests/test-AANA.sh",
    "tsxComponents": [
      "src/components/analytics/AdminAnalytics.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "spec": "docs/pagespecs/admin/AANA.md"
    }
  },
  "purpose": "Provide platform administrators with comprehensive analytics for monitoring app effectiveness, profitability, and growth metrics to inform business decisions and marketing strategy.",
  "connections": {
    "incoming": [
      {
        "source": "ADMN",
        "sourceRoute": "/admin",
        "trigger": "\"View Analytics\" link",
        "notes": "From admin dashboard"
      },
      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"Analytics\" link",
        "notes": "Admin navigation"
      }
    ],
    "outgoing": [
      {
        "target": "ADMN",
        "targetRoute": "/admin",
        "trigger": "Back/breadcrumb",
        "notes": "Return to dashboard"
      },
      {
        "target": "AUSR",
        "targetRoute": "/admin/users",
        "trigger": "\"View Users\"",
        "notes": "Drill into user data"
      },
      {
        "target": "ACRS",
        "targetRoute": "/admin/courses",
        "trigger": "\"View Courses\"",
        "notes": "Drill into course data"
      },
      {
        "target": "APAY",
        "targetRoute": "/admin/payouts",
        "trigger": "\"View Payouts\"",
        "notes": "Drill into payout data"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "users",
      "fields_used": "created_at, is_creator, is_student_teacher, is_student, suspended_at",
      "purpose": "User growth and role distribution"
    },
    {
      "entity": "courses",
      "fields_used": "created_at, is_active, student_count, rating",
      "purpose": "Course metrics and creator activity"
    },
    {
      "entity": "enrollments",
      "fields_used": "enrolled_at, status, progress_percent, completed_at",
      "purpose": "Enrollment trends and completion rates"
    },
    {
      "entity": "transactions",
      "fields_used": "amount_cents, paid_at, status",
      "purpose": "Revenue tracking"
    },
    {
      "entity": "payment_splits",
      "fields_used": "amount_cents, recipient_type, created_at",
      "purpose": "Revenue distribution analysis"
    },
    {
      "entity": "payouts",
      "fields_used": "amount_cents, status, paid_at",
      "purpose": "Payout tracking"
    },
    {
      "entity": "video_sessions",
      "fields_used": "scheduled_at, status, actual_duration_minutes",
      "purpose": "Session engagement metrics"
    },
    {
      "entity": "student_teachers",
      "fields_used": "certified_at, is_active, rating",
      "purpose": "S-T pipeline metrics"
    },
    {
      "entity": "certificates",
      "fields_used": "issued_at, status",
      "purpose": "Certification metrics"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Page title: \"Platform Analytics\"",
        "Period selector: 7d / 30d / 90d / 1y / All time",
        "Export button (future): CSV/PDF export"
      ]
    },
    {
      "title": "Executive Summary Cards (KPIs)",
      "items": [
        "**Total Revenue** - Gross revenue with % change",
        "**Platform Take** - 15% platform share with % change",
        "**Active Users** - MAU with % change",
        "**Completion Rate** - Platform-wide with trend",
        "**Net Promoter Score** - Average rating proxy (future)"
      ]
    },
    {
      "title": "Revenue & Profitability",
      "items": [
        "**Revenue Trend Chart** - Gross revenue over time (AreaChart)",
        "**Revenue Breakdown** - Platform (15%) vs Creator (15%) vs S-T (70%)",
        "**Average Order Value** - Revenue per enrollment trend",
        "**Payouts vs Revenue** - Cash flow visualization",
        "**MRR/ARR projection** (future)"
      ]
    },
    {
      "title": "User Growth & Acquisition",
      "items": [
        "**User Growth Chart** - New signups over time (AreaChart)",
        "**User Funnel** - Signup → Enrollment → Completion → Became S-T",
        "**Role Distribution** - Pie chart: Students, S-Ts, Creators, Multi-role",
        "**Cohort Retention** (future): Monthly cohort analysis"
      ]
    },
    {
      "title": "Course & Creator Metrics",
      "items": [
        "**Courses Published** - New courses over time",
        "**Top Courses Table** - By revenue, enrollments, completion rate",
        "**Creator Leaderboard** - Top creators by revenue",
        "**Course Health** - Avg rating, completion rate distribution",
        "**Category Performance** - Revenue by category"
      ]
    },
    {
      "title": "Student-Teacher Pipeline",
      "items": [
        "**S-T Growth Chart** - New certifications over time",
        "**S-T Conversion Funnel** - Completed → Recommended → Certified → Active",
        "**S-T Performance Distribution** - By students taught, rating",
        "**Flywheel Health** - Ratio of new S-Ts to new students"
      ]
    },
    {
      "title": "Engagement & Effectiveness",
      "items": [
        "**Session Metrics** - Total sessions, completion rate, avg duration",
        "**Sessions Trend** - Sessions over time (AreaChart)",
        "**Completion Rate Trend** - Platform-wide over time",
        "**Time to Completion** - Avg days from enrollment to completion",
        "**Progress Distribution** - Students by progress stage"
      ]
    },
    {
      "title": "Marketing Metrics (Future)",
      "items": [
        "**Traffic Sources** - Referral breakdown (needs tracking)",
        "**Conversion Rates** - Visit → Signup → Enrollment",
        "**CAC** - Customer acquisition cost (needs ad spend data)",
        "**LTV** - Lifetime value per user",
        "**LTV:CAC Ratio** - Unit economics health"
      ]
    }
  ],
  "userStories": [
    "US-ADM-060: View platform-wide analytics",
    "US-ADM-061: Track revenue and profitability",
    "US-ADM-062: Monitor user growth",
    "US-ADM-063: Assess course and creator performance",
    "US-ADM-064: Track S-T pipeline health",
    "US-ADM-065: Measure platform effectiveness"
  ],
  "statesVariations": [
    {
      "state": "Default",
      "description": "Last 30 days, all metrics"
    },
    {
      "state": "Custom Period",
      "description": "User-selected date range"
    },
    {
      "state": "Loading",
      "description": "Skeleton charts during fetch"
    },
    {
      "state": "Error",
      "description": "Failed to load with retry"
    },
    {
      "state": "Early Stage",
      "description": "Limited data, show benchmarks"
    }
  ],
  "mobileConsiderations": [
    "KPI cards in scrollable row",
    "Charts stack vertically",
    "Tables become card lists",
    "Period selector as dropdown"
  ],
  "errorHandling": [
    {
      "error": "Load fails",
      "display": "\"Unable to load analytics. [Retry]\""
    },
    {
      "error": "Partial data",
      "display": "Show available sections, note missing"
    }
  ],
  "analyticsEvents": [
    {
      "event": "`admin_analytics_view`",
      "trigger": "Page load",
      "data": "period, admin_id"
    },
    {
      "event": "`period_changed`",
      "trigger": "Period selector change",
      "data": "new_period"
    },
    {
      "event": "`export_requested`",
      "trigger": "Export button clicked",
      "data": "format, period"
    }
  ],
  "notes": [
    "More comprehensive than CANA - platform-wide view",
    "Key business metrics: Revenue, Completion Rate, Flywheel Health",
    "Flywheel ratio = new S-Ts / new students (target: 10-20%)",
    "Platform take is 15% of gross revenue",
    "Marketing metrics require additional tracking (PostHog/UTM)",
    "Consider adding comparison to targets/goals",
    "Export feature deferred to Phase 2"
  ],
