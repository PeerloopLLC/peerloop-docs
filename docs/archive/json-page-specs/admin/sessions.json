  "sections": [
    {
      "title": "Header",
      "items": [
        "Screen title: \"Session Management\"",
        "Stats: \"X sessions today, Y this week\"",
        "Date range selector"
      ]
    },
    {
      "title": "Filters",
      "items": [
        "**Search:** Student/ST name",
        "**Course filter:** All / specific course",
        "**Status filter:** All / Scheduled / Completed / Cancelled / No-show",
        "**Date filter:** Date range",
        "**Issues filter:** With disputes / Low ratings"
      ]
    },
    {
      "title": "Sessions Table",
      "items": [
        "| Column | Content |\n|--------|---------|\n| Date/Time | Session datetime |\n| Course | Course title |\n| Student | Student name |\n| ST | ST name |\n| Duration | Planned / Actual |\n| Status | Scheduled / Completed / Cancelled / No-show |\n| Ratings | Student → ST, ST → Student |\n| Recording | Available / Not available |\n| Actions | View, Resolve |"
      ]
    },
    {
      "title": "Session Detail Panel",
      "items": [
        "Date, time, duration",
        "Course + enrollment info",
        "Student info (link to AUSR)",
        "ST info (link to AUSR)",
        "Video room URL/ID",
        "Status (with timestamps)",
        "Student rating + comment",
        "ST rating + comment",
        "Recording link (if available)",
        "Flag reason",
        "Both party statements",
        "Resolution options:",
        "Resolution notes",
        "Resolve button"
      ]
    },
    {
      "title": "Actions",
      "items": [
        "| Action | Description |\n|--------|-------------|\n| View Recording | Play session recording |\n| Download Recording | Download for review |\n| Flag for Review | Mark session for follow-up |\n| Credit Session | Give student free session credit |\n| Warn User | Issue warning to student or ST |"
      ]
    },
    {
      "title": "Upcoming Sessions View",
      "items": [
        "Calendar/list of scheduled sessions",
        "For monitoring, not intervention",
        "Identify scheduling issues"
      ]
    }
  ],
