  "purpose": "CRUD interface for managing Student-Teacher certifications - view, activate/deactivate, revoke, and monitor teaching activity.",
  "connections": {
    "incoming": [
      {
        "source": "Admin Sidebar",
        "sourceRoute": "/admin",
        "trigger": "\"Student-Teachers\" nav item",
        "notes": "Primary entry point"
      },
      {
        "source": "AUSR",
        "sourceRoute": "/admin/users",
        "trigger": "\"View ST Certifications\"",
        "notes": "Not implemented yet"
      },
      {
        "source": "ACRS",
        "sourceRoute": "/admin/courses",
        "trigger": "\"View Student-Teachers\"",
        "notes": "Not implemented yet"
      }
    ],
    "outgoing": [
      {
        "target": "AUSR",
        "targetRoute": "/admin/users?user={id}",
        "trigger": "\"View Profile\" action",
        "notes": "View user in admin"
      },
      {
        "target": "AENR",
        "targetRoute": "/admin/enrollments?st={id}",
        "trigger": "\"View Students\" action",
        "notes": "Filtered to ST's enrollments"
      },
      {
        "target": "ASES",
        "targetRoute": "/admin/sessions?st={id}",
        "trigger": "\"View Sessions\" action",
        "notes": "Filtered to ST (target is PageSpecView)"
      },
      {
        "target": "CPRO",
        "targetRoute": "/creators/{handle}",
        "trigger": "\"View Public Profile\" button",
        "notes": "Opens creator profile"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "student_teachers",
      "fields_used": "All fields",
      "purpose": "ST certification records"
    },
    {
      "entity": "users (ST)",
      "fields_used": "id, name, email, handle, avatar_url",
      "purpose": "Student-Teacher info"
    },
    {
      "entity": "users (approver)",
      "fields_used": "id, name",
      "purpose": "Creator who approved certification"
    },
    {
      "entity": "courses",
      "fields_used": "id, title, slug",
      "purpose": "Course info"
    },
    {
      "entity": "enrollments",
      "fields_used": "student_teacher_id, count",
      "purpose": "Active student count"
    },
    {
      "entity": "sessions",
      "fields_used": "student_teacher_id, count",
      "purpose": "Session stats"
    },
    {
      "entity": "session_assessments",
      "fields_used": "rating",
      "purpose": "Average rating calculation"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Title: \"Student-Teacher Management\"",
        "Subtitle: \"Manage ST certifications, monitor teaching activity\"",
        "Stats cards: Total STs, Active STs, Students Taught, Avg Rating"
      ]
    },
    {
      "title": "Stats Cards",
      "items": [
        "Total STs - count from API",
        "Active - count of active STs",
        "Students Taught - sum of all students_taught",
        "Avg Rating - average rating across all STs (or \"-\" if none)"
      ]
    },
    {
      "title": "Filter Bar",
      "items": [
        "Search input with placeholder \"Search by name, email, or course...\"",
        "Course dropdown (All Courses / specific courses)",
        "Status dropdown (All Statuses / Active / Inactive)"
      ]
    },
    {
      "title": "Data Table",
      "items": [
        "| Column | Content |",
        "|--------|---------|",
        "| Student-Teacher | Avatar + Name + @handle |",
        "| Course | Course title |",
        "| Certified | Date + \"X ago\" |",
        "| Students | N total (+ \"N active\" if any) |",
        "| Sessions | Count |",
        "| Rating | Star + number or \"-\" |",
        "| Status | Active/Inactive badge |",
        "| Actions | 3-dot menu |"
      ]
    },
    {
      "title": "Detail Panel",
      "items": [
        "ST name and handle",
        "Status badge",
        "Contact info (name, handle, email)",
        "Course info (title, certified date, time as ST, approved by)",
        "Teaching stats (total students, active, completed, sessions, avg rating)",
        "Recent students list (up to 5)",
        "Recent sessions list (up to 5)",
        "Metadata (IDs)",
        "Footer: View Profile, Activate/Deactivate buttons"
      ]
    },
    {
      "title": "Actions",
      "items": [
        "| Action | Description |",
        "|--------|-------------|",
        "| View Details | Opens detail panel |",
        "| View Profile | Navigate to /admin/users?user={id} |",
        "| View Students | Navigate to /admin/enrollments?st={id} |",
        "| View Sessions | Navigate to /admin/sessions?st={id} |",
        "| Activate | Enable ST to accept students |",
        "| Deactivate | Disable (with confirmation if has active students) |",
        "| Revoke Certification | Delete (blocked if has active students) |"
      ]
    }
  ],
  "userStories": [
    "US-A040",
    "US-A041",
    "US-A042",
    "US-A043"
  ],
