  "analyticsEvents": [],
  "notes": [
    "ST certification is per-course (one user can be ST for multiple courses)",
    "Deactivating prevents new student assignments but keeps existing relationships",
    "Revocation requires confirmation and is blocked if active students assigned",
    "API TODOs: notification sending (Block 9), admin audit logging (future)"
  ],
