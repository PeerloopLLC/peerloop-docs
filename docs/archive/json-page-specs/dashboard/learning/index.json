  "purpose": "Central hub for students to track their enrolled courses, upcoming sessions, learning progress, and quickly access key actions.",
  "connections": {
    "incoming": [
      {
        "source": "LGIN",
        "sourceRoute": "/login",
        "trigger": "Successful login (Student role)",
        "notes": "Default post-login destination"
      },
      {
        "source": "SGUP",
        "sourceRoute": "/signup",
        "trigger": "Successful signup",
        "notes": "After onboarding"
      },
      {
        "source": "Nav",
        "trigger": "\"Dashboard\" link",
        "notes": "Global navigation"
      },
      {
        "source": "SROM",
        "sourceRoute": "/session/[id]",
        "trigger": "\"Back to Dashboard\"",
        "notes": "After session ends"
      },
      {
        "source": "CCNT",
        "sourceRoute": "/courses/[slug]/learn",
        "trigger": "\"Dashboard\" link",
        "notes": "From course content"
      },
      {
        "source": "Any page",
        "trigger": "Logo click (logged in)",
        "notes": "May go to dashboard"
      }
    ],
    "outgoing": [
      {
        "target": "CCNT",
        "targetRoute": "/courses/[slug]/learn",
        "trigger": "\"Continue Learning\" on course card",
        "notes": "Resume course content"
      },
      {
        "target": "SBOK",
        "targetRoute": "/courses/[slug]/book",
        "trigger": "\"Book Session\" / \"Schedule\"",
        "notes": "Book next session"
      },
      {
        "target": "SROM",
        "targetRoute": "/session/[id]",
        "trigger": "\"Join Session\"",
        "notes": "Active session join"
      },
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course title click",
        "notes": "View course details"
      },
      {
        "target": "FEED",
        "targetRoute": "/community",
        "trigger": "\"Community\" nav",
        "notes": "Go to feed"
      },
      {
        "target": "CBRO",
        "targetRoute": "/courses",
        "trigger": "\"Browse Courses\"",
        "notes": "Find new courses"
      },
      {
        "target": "PROF",
        "targetRoute": "/settings",
        "trigger": "\"Settings\" nav",
        "notes": "Edit profile/settings"
      },
      {
        "target": "STPR",
        "targetRoute": "/teachers/[handle]",
        "trigger": "\"Your Teacher\" link",
        "notes": "View assigned ST"
      },
      {
        "target": "NOTF",
        "targetRoute": "/notifications",
        "trigger": "Notification bell",
        "notes": "View all notifications"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "enrollments",
      "fields_used": "id, course_id, student_teacher_id, status, enrolled_at",
      "purpose": "Enrolled courses list"
    },
    {
      "entity": "courses",
      "fields_used": "id, title, thumbnail, slug",
      "purpose": "Course display"
    },
    {
      "entity": "module_progress",
      "fields_used": "enrollment_id, is_complete",
      "purpose": "Progress calculation"
    },
    {
      "entity": "course_curriculum",
      "fields_used": "id, course_id",
      "purpose": "Total modules for progress"
    },
    {
      "entity": "users (ST)",
      "fields_used": "name, avatar",
      "purpose": "Assigned teacher display"
    }
  ],
