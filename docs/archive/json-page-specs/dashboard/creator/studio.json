  "errorHandling": [
    {
      "error": "Save fails",
      "display": "\"Unable to save. Please try again.\""
    },
    {
      "error": "Publish fails",
      "display": "\"Unable to publish. Check required fields.\""
    },
    {
      "error": "Image upload fails",
      "display": "\"Unable to upload image. Try again.\""
    },
    {
      "error": "Slug conflict",
      "display": "\"This URL is already taken. Choose another.\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "view (list/edit), course_id"
    },
    {
      "event": "`course_created`",
      "trigger": "New course started",
      "data": "-"
    },
    {
      "event": "`course_updated`",
      "trigger": "Changes saved",
      "data": "course_id, fields_changed"
    },
    {
      "event": "`course_published`",
      "trigger": "Published",
      "data": "course_id"
    },
    {
      "event": "`course_unpublished`",
      "trigger": "Unpublished",
      "data": "course_id"
    },
    {
      "event": "`module_added`",
      "trigger": "Module created",
      "data": "course_id"
    },
    {
      "event": "`module_reordered`",
      "trigger": "Modules reordered",
      "data": "course_id"
    }
  ],
