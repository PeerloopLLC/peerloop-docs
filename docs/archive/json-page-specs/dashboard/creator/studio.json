  "purpose": "Course creation and management interface for Creators to build, edit, publish, and manage their courses and curriculum.",
  "connections": {
    "incoming": [
      {
        "source": "CDSH",
        "sourceRoute": "/dashboard/creator",
        "trigger": "\"Creator Studio\" / \"Manage Courses\"",
        "notes": "From dashboard"
      },
      {
        "source": "CDSH",
        "sourceRoute": "/dashboard/creator",
        "trigger": "\"Create New Course\"",
        "notes": "Direct to new course"
      },
      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"Studio\" link (Creators)",
        "notes": "Global navigation"
      },
      {
        "source": "CDET",
        "sourceRoute": "/courses/[slug]",
        "trigger": "\"Edit Course\" (own course)",
        "notes": "Edit specific course"
      }
    ],
    "outgoing": [
      {
        "target": "CDSH",
        "targetRoute": "/dashboard/creator",
        "trigger": "\"Dashboard\" / back",
        "notes": "Return to dashboard"
      },
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "\"Preview Course\"",
        "notes": "View public course page"
      },
      {
        "target": "CPRO",
        "targetRoute": "/creators/[handle]",
        "trigger": "\"View Profile\"",
        "notes": "See creator profile"
      }
    ]
  },
