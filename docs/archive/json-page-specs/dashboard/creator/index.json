    "incoming": [
      {
        "source": "LGIN",
        "sourceRoute": "/login",
        "trigger": "Successful login (Creator role)",
        "notes": "Default post-login"
      },
      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"Dashboard\" link",
        "notes": "Global navigation"
      },
      {
        "source": "STUD",
        "sourceRoute": "/dashboard/creator/studio",
        "trigger": "\"Dashboard\" link",
        "notes": "From Creator Studio"
      },
      {
        "source": "CPRO",
        "sourceRoute": "/creators/[handle]",
        "trigger": "\"Dashboard\" link",
        "notes": "From own profile"
      }
    ],
    "outgoing": [
      {
        "target": "STUD",
        "targetRoute": "/dashboard/creator/studio",
        "trigger": "\"Creator Studio\" / \"Manage Courses\"",
        "notes": "Course management"
      },
      {
        "target": "CPRO",
        "targetRoute": "/creators/[handle]",
        "trigger": "\"View Public Profile\"",
        "notes": "See public creator profile"
      },
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course card click",
        "notes": "View course detail"
      },
      {
        "target": "CANA",
        "targetRoute": "/dashboard/creator/analytics",
        "trigger": "\"View Analytics\"",
        "notes": "Detailed analytics"
      }
    ]
  },
