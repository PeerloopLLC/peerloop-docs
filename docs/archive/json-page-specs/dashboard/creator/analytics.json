{
  "metadata": {
    "title": "Creator Analytics",
    "code": "CANA",
    "route": "/dashboard/creator/analytics",
    "astroFile": "src/pages/dashboard/creator/analytics.astro",
    "access": "Creator",
    "priority": "P1",
    "testScript": "scripts/page-tests/test-CANA.sh",
    "tsxComponents": [
      "src/components/analytics/CreatorAnalytics.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/CANA/CANA.md",
      "audit": "docs/pages/CANA/AUDIT-CANA.md",
      "spec": "docs/pagespecs/dashboard/creator/CANA.md"
    }
  },
  "purpose": "Provide Creators with detailed analytics about their courses, student engagement, conversion rates, and revenue performance.",
  "connections": {
    "incoming": [
      {
        "source": "CDSH",
        "sourceRoute": "/dashboard/creator",
        "trigger": "\"View Analytics\" link",
        "notes": "From dashboard"
      },
      {
        "source": "STUD",
        "sourceRoute": "/dashboard/creator/studio",
        "trigger": "\"Analytics\" tab",
        "notes": "From Creator Studio"
      },
      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"Analytics\" link",
        "notes": "Creator navigation"
      }
    ],
    "outgoing": [
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course name click",
        "notes": "View course"
      },
      {
        "target": "CMST",
        "targetRoute": "/dashboard/teaching/students",
        "trigger": "\"View Students\" link",
        "notes": "Student details"
      },
      {
        "target": "CEAR",
        "targetRoute": "/dashboard/teaching/earnings",
        "trigger": "\"View Earnings\" link",
        "notes": "Revenue details"
      },
      {
        "target": "CDSH",
        "targetRoute": "/dashboard/creator",
        "trigger": "Back/breadcrumb",
        "notes": "Return to dashboard"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "courses",
      "fields_used": "id, title, student_count, rating",
      "purpose": "Course list"
    },
    {
      "entity": "enrollments",
      "fields_used": "course_id, status, enrolled_at, completed_at",
      "purpose": "Enrollment metrics"
    },
    {
      "entity": "sessions",
      "fields_used": "course_id, status, scheduled_start",
      "purpose": "Session metrics"
    },
    {
      "entity": "module_progress",
      "fields_used": "enrollment_id, is_complete, completed_at",
      "purpose": "Progress metrics"
    },
    {
      "entity": "certificates",
      "fields_used": "course_id, type, issued_at",
      "purpose": "Completion metrics"
    },
    {
      "entity": "transactions",
      "fields_used": "enrollment_id, amount_cents, paid_at",
      "purpose": "Revenue data"
    },
    {
      "entity": "(page_views)",
      "fields_used": "course_id, timestamp",
      "purpose": "Traffic data (if tracked)"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Page title: \"Analytics\"",
        "Date range selector (7d, 30d, 90d, 1y, custom)",
        "Course filter: All / specific course"
      ]
    },
    {
      "title": "Key Metrics Row",
      "items": [
        "**Total Revenue** (period)",
        "**New Enrollments** (period)",
        "**Completion Rate** (%)",
        "**Average Rating**",
        "**Active Students**"
      ]
    },
    {
      "title": "Enrollment Trends Chart",
      "items": [
        "Line/area chart: Enrollments over time",
        "Overlay: Revenue over time",
        "Comparison to previous period"
      ]
    },
    {
      "title": "Course Performance Table",
      "items": [
        "| Column | Content |\n|--------|---------|\n| Course | Title |\n| Enrollments | Total / Period |\n| Revenue | Total / Period |\n| Completion Rate | % completed |\n| Avg Rating | Stars |\n| Active | Current active students |"
      ]
    },
    {
      "title": "Funnel Analysis",
      "items": [
        "Course page views → Enrollments → Completions → Became ST",
        "Conversion rates at each step",
        "Drop-off identification"
      ]
    },
    {
      "title": "Student Progress Distribution",
      "items": [
        "Pie/bar chart: Students by progress stage"
      ]
    },
    {
      "title": "Session Analytics",
      "items": [
        "Sessions per week trend",
        "Average session duration",
        "Session completion rate",
        "No-show rate"
      ]
    },
    {
      "title": "ST Performance",
      "items": [
        "Leaderboard: Top STs by students taught",
        "Average ratings per ST",
        "Session volume per ST"
      ]
    },
    {
      "title": "Engagement Metrics",
      "items": [
        "Average time to first session",
        "Average days to completion",
        "Module completion rates",
        "Content engagement (if tracked)"
      ]
    }
  ],
  "userStories": [
    "US-C033: View course analytics",
    "US-C047: Track conversion rates",
    "US-C048: Monitor student engagement",
    "US-C049: Analyze revenue trends"
  ],
  "statesVariations": [
    {
      "state": "Default",
      "description": "All courses, last 30 days"
    },
    {
      "state": "Filtered",
      "description": "Specific course or date range"
    },
    {
      "state": "Comparison",
      "description": "Comparing to previous period"
    },
    {
      "state": "Empty",
      "description": "No data yet, \"Share your courses\""
    }
  ],
  "mobileConsiderations": [
    "Metrics row scrolls horizontally",
    "Charts simplified for mobile",
    "Tables become card lists",
    "Focus on key metrics"
  ],
  "errorHandling": [
    {
      "error": "Load fails",
      "display": "\"Unable to load analytics. [Retry]\""
    },
    {
      "error": "Partial data",
      "display": "Show available data with notice"
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "date_range, course_filter"
    },
    {
      "event": "`date_range_changed`",
      "trigger": "Range selected",
      "data": "new_range"
    },
    {
      "event": "`course_filtered`",
      "trigger": "Course selected",
      "data": "course_id"
    },
    {
      "event": "`export_requested`",
      "trigger": "Export clicked",
      "data": "report_type"
    }
  ],
  "notes": [
    "Consider caching/pre-computing metrics for performance",
    "Charts should be interactive (hover for details)",
    "Export to CSV/PDF for reporting",
    "Future: Cohort analysis, predictive metrics",
    "NOTE: apiCalls paths need updating - actual routes are /api/me/creator-analytics/*"
  ],
