      "description": "Newsletter being sent (progress indicator)"
    }
  ],
  "mobileConsiderations": [
    "Newsletter editing may be limited on mobile (complex rich text)",
    "Consider mobile-optimized preview"
  ],
  "errorHandling": [
    {
      "error": "Send fails",
      "display": "\"Newsletter failed to send. [Retry]\""
    },
    {
      "error": "No subscribers",
      "display": "\"You have no subscribers yet\""
    }
  ],
