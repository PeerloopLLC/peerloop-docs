  "purpose": "Allow Creators to publish newsletters to their subscribers, with optional paid subscription tiers.",
  "connections": {
    "incoming": [
      {
        "source": "STUD",
        "sourceRoute": "/dashboard/creator/studio",
        "trigger": "\"Newsletters\" nav item",
        "notes": "Creator Studio sidebar"
      },
      {
        "source": "CDSH",
        "sourceRoute": "/dashboard/creator",
        "trigger": "\"Manage Newsletters\" link",
        "notes": "Dashboard quick action"
      }
    ],
    "outgoing": [
      {
        "target": "STUD",
        "targetRoute": "/dashboard/creator/studio",
        "trigger": "Back/breadcrumb",
        "notes": "Return to studio"
      },
      {
        "target": "(External)",
        "targetRoute": "",
        "trigger": "\"Preview\" button",
        "notes": "Opens newsletter preview"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "newsletters",
      "fields_used": "id, title, content, status, sent_at, creator_id",
      "purpose": "Newsletter records"
    },
    {
      "entity": "newsletter_subscribers",
      "fields_used": "user_id, creator_id, tier, subscribed_at",
      "purpose": "Subscriber list"
    },
    {
      "entity": "newsletter_tiers",
      "fields_used": "id, name, price, description",
      "purpose": "Subscription tiers"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Page title: \"Newsletters\"",
        "\"Create Newsletter\" button"
      ]
    },
    {
      "title": "Newsletter List",
      "items": [
        "Table/cards of past newsletters",
        "Columns: Title, Status (Draft/Sent), Sent Date, Opens, Clicks",
        "Actions: Edit, Duplicate, Delete, View Stats"
      ]
    },
    {
      "title": "Create/Edit Newsletter",
      "items": [
        "Title field",
        "Rich text editor for content",
        "Subscriber tier selector (who receives)",
        "Schedule or send immediately",
        "Preview button"
      ]
    },
    {
      "title": "Subscriber Management",
      "items": [
        "Subscriber count by tier",
        "Export subscribers",
        "Tier management (create/edit tiers)"
      ]
    }
  ],
  "userStories": [
    "US-C026: As a Creator, I need to publish newsletters (potentially with subscription payments) so that I can engage my audience"
  ],
  "statesVariations": [
