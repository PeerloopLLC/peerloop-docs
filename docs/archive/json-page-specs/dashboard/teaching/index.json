{
  "metadata": {
    "title": "Student-Teacher Dashboard",
    "code": "TDSH",
    "route": "/dashboard/teaching",
    "astroFile": "src/pages/dashboard/teaching/index.astro",
    "access": "StudentTeacher",
    "priority": "P0",
    "testScript": "scripts/page-tests/test-TDSH.sh",
    "tsxComponents": [
      "src/components/dashboard/TeacherDashboard.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/TDSH/TDSH.md",
      "spec": "docs/pagespecs/dashboard/teaching/TDSH.md"
    }
  },
  "purpose": "Central hub for Student-Teachers to manage their teaching schedule, track earnings, view their students, and handle teaching-related tasks.",
  "connections": {
    "incoming": [
      {
        "source": "LGIN",
        "sourceRoute": "/login",
        "trigger": "Successful login (ST role)",
        "notes": "Default post-login"
      },
      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"Dashboard\" link",
        "notes": "Global navigation"
      },
      {
        "source": "SROM",
        "sourceRoute": "/session/[id]",
        "trigger": "\"Back to Dashboard\"",
        "notes": "After teaching session"
      },
      {
        "source": "PROF",
        "sourceRoute": "/profile",
        "trigger": "\"Dashboard\" link",
        "notes": "From profile"
      }
    ],
    "outgoing": [
      {
        "target": "SROM",
        "targetRoute": "/session/[id]",
        "trigger": "\"Join Session\"",
        "notes": "Join teaching session"
      },
      {
        "target": "STPR",
        "targetRoute": "/teachers/[handle]",
        "trigger": "\"View My Profile\"",
        "notes": "See public ST profile"
      },
      {
        "target": "PROF",
        "targetRoute": "/profile",
        "trigger": "\"Edit Profile\"",
        "notes": "Edit profile settings"
      },
      {
        "target": "SETT",
        "targetRoute": "/settings",
        "trigger": "\"Availability\"",
        "notes": "Manage teaching schedule"
      },
      {
        "target": "MSGS",
        "targetRoute": "/messages",
        "trigger": "\"Message Student\"",
        "notes": "Contact a student"
      },
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course title click",
        "notes": "View course info"
      },
      {
        "target": "(Payout)",
        "targetRoute": "",
        "trigger": "\"Request Payout\"",
        "notes": "Initiate payout (future)"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "sessions",
      "fields_used": "id, scheduled_start, student_id, course_id, status",
      "purpose": "Teaching schedule"
    },
    {
      "entity": "student_teachers",
      "fields_used": "course_id, students_taught, is_active",
      "purpose": "Certification status"
    },
    {
      "entity": "payment_splits",
      "fields_used": "amount_cents, status",
      "purpose": "Earnings tracking"
    },
    {
      "entity": "payouts",
      "fields_used": "amount_cents, status, paid_at",
      "purpose": "Payout history"
    },
    {
      "entity": "enrollments",
      "fields_used": "student_id, course_id",
      "purpose": "My students list"
    },
    {
      "entity": "users (students)",
      "fields_used": "name, avatar",
      "purpose": "Student display"
    },
    {
      "entity": "courses",
      "fields_used": "id, title",
      "purpose": "Course info"
    },
    {
      "entity": "certificates",
      "fields_used": "user_id, course_id, type, recommended_by",
      "purpose": "Pending recommendations"
    },
    {
      "entity": "homework_submissions",
      "fields_used": "id, status, student_id, assignment_id",
      "purpose": "Pending homework reviews"
    },
    {
      "entity": "homework_assignments",
      "fields_used": "id, title, course_id",
      "purpose": "Assignment context"
    }
  ],
  "sections": [
    {
      "title": "Header Bar",
      "items": [
        "Greeting: \"Welcome, Teacher [Name]!\"",
        "Availability toggle: \"Available for Summon\" (if goodwill enabled)",
        "Quick stats: X students, Y sessions this week"
      ]
    },
    {
      "title": "Earnings Overview",
      "items": [
        "**Pending Balance:** Amount awaiting payout",
        "**Total Earned:** Lifetime earnings",
        "**This Month:** Current month earnings",
        "\"View Earnings Details\" → detailed breakdown",
        "\"Request Payout\" button (if eligible)"
      ]
    },
    {
      "title": "Upcoming Teaching Sessions",
      "items": [
        "Next 5 scheduled sessions",
        "Each shows:",
        "Empty state: \"No sessions scheduled\""
      ]
    },
    {
      "title": "My Students",
      "items": [
        "List of students currently learning from this ST",
        "Each shows:",
        "Grouped by course if teaching multiple"
      ]
    },
    {
      "title": "Pending Actions",
      "items": [
        "**Certification Recommendations:**",
        "**Intro Session Requests** (per CD-029):",
        "**Homework Reviews:**",
        "Empty state: \"No pending actions\""
      ]
    },
    {
      "title": "Availability Quick View",
      "items": [
        "Weekly calendar showing available slots",
        "\"Edit Availability\" → SETT"
      ]
    },
    {
      "title": "Teaching Stats",
      "items": [
        "Sessions completed this month",
        "Average session rating",
        "Students helped"
      ]
    }
  ],
  "userStories": [
    "US-T013: Access ST-specific dashboard",
    "US-T023: View teaching earnings",
    "US-P061: Recommend students for certification"
  ],
  "statesVariations": [
    {
      "state": "New ST",
      "description": "Just certified, no sessions yet, onboarding tips"
    },
    {
      "state": "Active ST",
      "description": "Sessions scheduled, students assigned"
    },
    {
      "state": "Session Starting",
      "description": "\"Join Now\" prominently displayed"
    },
    {
      "state": "Payout Available",
      "description": "Highlight pending balance, enable payout"
    },
    {
      "state": "Multi-Role",
      "description": "Combined with student sections (unified dashboard)"
    }
  ],
  "mobileConsiderations": [
    "Earnings summary at top (primary concern for STs)",
    "Sessions list scrollable",
    "Sticky \"Join Session\" if imminent",
    "Quick toggle for availability"
  ],
  "errorHandling": [
    {
      "error": "Data load fails",
      "display": "\"Unable to load dashboard. [Retry]\""
    },
    {
      "error": "Payout request fails",
      "display": "\"Unable to process. Please try again.\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "sessions_count, earnings_pending"
    },
    {
      "event": "`join_session`",
      "trigger": "Join clicked",
      "data": "session_id"
    },
    {
      "event": "`recommend_cert`",
      "trigger": "Recommend clicked",
      "data": "student_id, course_id"
    },
    {
      "event": "`view_earnings`",
      "trigger": "Earnings detail clicked",
      "data": "-"
    },
    {
      "event": "`request_payout`",
      "trigger": "Payout clicked",
      "data": "amount"
    }
  ],
  "notes": [
    "Multi-role users: May see both learning + teaching sections",
    "CD-033: ST gets 70% when teaching Creator's course content",
    "CD-033: ST gets 85% when teaching their own content (no Creator)",
    "Consider combining SDSH + TDSH into unified role-aware dashboard",
    "Real-time notification for new session bookings",
    "Payout requires active Stripe Connect (see SETT)"
  ],
  "plannedApiCalls": [],
  "testCoverage": {
    "pageTest": {
      "file": "tests/pages/dashboard/teaching/index.test.tsx",
      "exists": false
    },
    "componentTest": {
      "file": "tests/components/dashboard/TeacherDashboard.test.tsx",
      "exists": true
    },
    "apiTests": [
      {
        "endpoint": "GET /api/me/teacher-dashboard",
        "testFile": "tests/api/me/teacher-dashboard.test.ts",
        "tested": true
      },
      {
        "endpoint": "GET /api/me/st-analytics",
        "testFile": "tests/api/me/st-analytics/index.test.ts",
        "tested": true
      },
      {
        "endpoint": "GET /api/me/st-students",
        "testFile": "tests/api/me/st-students.test.ts",
        "tested": true
      },
      {
        "endpoint": "GET /api/me/st-sessions",
        "testFile": "tests/api/me/st-sessions.test.ts",
        "tested": true
      }
    ],
    "summary": {
      "pageTest": false,
      "componentTest": true,
      "apiCoverage": "4/4",
      "readyToWork": true
    }
  }
}
