{
  "metadata": {
    "title": "My Students (Creator)",
    "code": "CMST",
    "route": "/dashboard/teaching/students",
    "astroFile": "src/pages/dashboard/teaching/students.astro",
    "access": "StudentTeacher",
    "priority": "P0",
    "testScript": "scripts/page-tests/test-CMST.sh",
    "tsxComponents": [
      "src/components/student-teachers/workspace/MyStudents.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/CMST/CMST.md",
      "spec": "docs/pagespecs/dashboard/teaching/CMST.md"
    }
  },
  "purpose": "Allow Creators to view and manage all students enrolled in their courses, track individual progress, and facilitate communication.",
  "connections": {
    "incoming": [
      {
        "source": "CDSH",
        "sourceRoute": "/dashboard/creator",
        "trigger": "\"View All Students\" link",
        "notes": "From dashboard"
      },
      {
        "source": "STUD",
        "sourceRoute": "/dashboard/creator/studio",
        "trigger": "\"Students\" tab/link",
        "notes": "From Creator Studio"
      },
      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"My Students\" link",
        "notes": "Creator navigation"
      }
    ],
    "outgoing": [
      {
        "target": "PROF",
        "targetRoute": "/profile",
        "trigger": "Student name click",
        "notes": "View student profile"
      },
      {
        "target": "MSGS",
        "targetRoute": "/messages",
        "trigger": "\"Message\" button",
        "notes": "Contact student"
      },
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course name click",
        "notes": "View course"
      },
      {
        "target": "CSES",
        "targetRoute": "/dashboard/teaching/sessions",
        "trigger": "\"View Sessions\" on student row",
        "notes": "Session history with student"
      },
      {
        "target": "CDSH",
        "targetRoute": "/dashboard/creator",
        "trigger": "Back/breadcrumb",
        "notes": "Return to dashboard"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "enrollments",
      "fields_used": "id, student_id, course_id, status, enrolled_at, completed_at",
      "purpose": "Enrollment records"
    },
    {
      "entity": "users (students)",
      "fields_used": "id, name, avatar, email, handle",
      "purpose": "Student info"
    },
    {
      "entity": "courses",
      "fields_used": "id, title (where creator_id = current user)",
      "purpose": "Course filter"
    },
    {
      "entity": "module_progress",
      "fields_used": "enrollment_id, is_complete",
      "purpose": "Progress calculation"
    },
    {
      "entity": "sessions",
      "fields_used": "enrollment_id, status, scheduled_start",
      "purpose": "Session counts"
    },
    {
      "entity": "certificates",
      "fields_used": "user_id, course_id, type",
      "purpose": "Completion status"
    },
    {
      "entity": "student_teachers",
      "fields_used": "user_id, course_id",
      "purpose": "If student became ST"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Page title: \"My Students\"",
        "Total count: \"X students across Y courses\"",
        "Export button (CSV)"
      ]
    },
    {
      "title": "Filters & Search",
      "items": [
        "**Search:** By student name or email",
        "**Course filter:** All courses / specific course",
        "**Status filter:** All / Active / Completed / Cancelled",
        "**Sort:** Name, Enrollment date, Progress, Last activity"
      ]
    },
    {
      "title": "Student List/Table",
      "items": [
        "| Column | Content |\n|--------|---------|\n| Student | Avatar + name + handle |\n| Course | Course title |\n| Enrolled | Date enrolled |\n| Progress | Progress bar (% modules complete) |\n| Sessions | X completed / Y scheduled |\n| Status | Active / Completed / At Risk |\n| Actions | Message, View Sessions, View Profile |"
      ]
    },
    {
      "title": "Student Row Actions",
      "items": [
        "**Message** → MSGS (pre-filled recipient)",
        "**View Sessions** → CSES (filtered to this student)",
        "**View Profile** → PROF",
        "**Mark at Risk** (flag for follow-up)"
      ]
    },
    {
      "title": "Bulk Actions",
      "items": [
        "Select multiple students",
        "Bulk message",
        "Export selected"
      ]
    },
    {
      "title": "Student Detail Panel (Slide-out or Modal)",
      "items": [
        "Full student info",
        "Course progress breakdown by module",
        "Session history",
        "Notes (creator's private notes on student)",
        "Assigned ST info",
        "Certificate status"
      ]
    }
  ],
  "userStories": [
    "US-C039: View enrolled students",
    "US-C040: Track student progress",
    "US-C041: Contact students",
    "US-C042: Export student data"
  ],
  "statesVariations": [
    {
      "state": "Default",
      "description": "All students, sorted by enrollment date"
    },
    {
      "state": "Filtered",
      "description": "By course or status"
    },
    {
      "state": "Empty",
      "description": "No students yet, \"Share your courses\" CTA"
    },
    {
      "state": "Detail Open",
      "description": "Student detail panel visible"
    }
  ],
  "mobileConsiderations": [
    "Card-based list instead of table",
    "Filters in collapsible drawer",
    "Detail panel becomes full screen",
    "Key actions (message) prominent"
  ],
  "errorHandling": [
    {
      "error": "Load fails",
      "display": "\"Unable to load students. [Retry]\""
    },
    {
      "error": "Export fails",
      "display": "\"Export failed. Try again.\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "student_count, filter_state"
    },
    {
      "event": "`student_viewed`",
      "trigger": "Detail opened",
      "data": "student_id, course_id"
    },
    {
      "event": "`student_messaged`",
      "trigger": "Message clicked",
      "data": "student_id"
    },
    {
      "event": "`export_requested`",
      "trigger": "Export clicked",
      "data": "count, format"
    }
  ],
  "notes": [
    "Consider \"At Risk\" auto-flagging based on inactivity",
    "Privacy: Only show students enrolled in creator's courses",
    "Could integrate with email campaigns (future)"
  ],
  "plannedApiCalls": [
    {
      "endpoint": "GET /api/me/st-students",
      "when": "Page load",
      "purpose": "List students assigned to current ST",
      "notes": "Response is camelCase. Returns: id, name, handle, avatarUrl (UserCardCompact fields) plus enrollment context: enrollmentId, courseId, courseTitle, courseSlug, enrolledAt, completedAt, status, progressPercent, modulesCompleted, modulesTotal, sessionsCompleted, sessionsScheduled, lastSessionAt, isCertified"
    },
    {
      "endpoint": "GET /api/me/st-students?courseId={courseId}",
      "when": "Filter by course",
      "purpose": "Students for a specific course"
    },
    {
      "endpoint": "GET /api/me/st-students?status=in_progress",
      "when": "Filter by status",
      "purpose": "Filter by enrollment status (enrolled, in_progress, completed, cancelled)"
    },
    {
      "endpoint": "GET /api/me/st-students?sort=progress&order=asc",
      "when": "Sort",
      "purpose": "Sort options: name, enrolledAt, progress, lastSession (with order asc/desc)"
    },
    {
      "endpoint": "GET /api/enrollments/:id/progress",
      "when": "Detail open",
      "purpose": "Module-by-module progress breakdown"
    },
    {
      "endpoint": "GET /api/enrollments/:id/sessions",
      "when": "Detail open",
      "purpose": "Session history with this student"
    }
  ],
  "_userListingTodo": {
    "description": "This page displays students assigned to the current ST using /api/me/st-students",
    "endpoint": "GET /api/me/st-students",
    "componentToUse": "Custom student card extending UserCardCompact with progress/session info",
    "filters": "courseId (from response.courses dropdown), status, search",
    "sortOptions": ["name", "enrolledAt", "progress", "lastSession"],
    "responseIncludes": "Student list with enrollment context, plus courses[] for filter dropdown",
    "pagination": "Uses page/limit params, returns totalPages in response",
    "addedAt": "2026-02-03"
  },
