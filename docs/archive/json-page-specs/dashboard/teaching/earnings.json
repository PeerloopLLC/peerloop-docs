{
  "metadata": {
    "title": "Earnings Detail (Creator)",
    "code": "CEAR",
    "route": "/dashboard/teaching/earnings",
    "astroFile": "src/pages/dashboard/teaching/earnings.astro",
    "access": "StudentTeacher",
    "priority": "P0",
    "testScript": "scripts/page-tests/test-CEAR.sh",
    "tsxComponents": [
      "src/components/student-teachers/workspace/EarningsDetail.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/CEAR/CEAR.md",
      "spec": "docs/pagespecs/dashboard/teaching/CEAR.md"
    }
  },
  "purpose": "Provide Creators with detailed view of their earnings, revenue breakdown by course, payout history, and pending balances.",
  "connections": {
    "incoming": [
      {
        "source": "CDSH",
        "sourceRoute": "/dashboard/creator",
        "trigger": "\"View Earnings\" link",
        "notes": "From earnings summary"
      },
      {
        "source": "CANA",
        "sourceRoute": "/dashboard/creator/analytics",
        "trigger": "\"View Earnings\" link",
        "notes": "From analytics"
      },
      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"Earnings\" link",
        "notes": "Creator navigation"
      },
      {
        "source": "STUD",
        "sourceRoute": "/dashboard/creator/studio",
        "trigger": "\"Earnings\" tab",
        "notes": "From Creator Studio"
      }
    ],
    "outgoing": [
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "Course name click",
        "notes": "View course"
      },
      {
        "target": "SETT",
        "targetRoute": "/settings",
        "trigger": "\"Payment Settings\"",
        "notes": "Update payout method"
      },
      {
        "target": "CDSH",
        "targetRoute": "/dashboard/creator",
        "trigger": "Back/breadcrumb",
        "notes": "Return to dashboard"
      },
      {
        "target": "(Stripe)",
        "targetRoute": "",
        "trigger": "\"View in Stripe\"",
        "notes": "External link"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "payment_splits",
      "fields_used": "amount_cents, status, released_at (where recipient = creator)",
      "purpose": "Revenue records"
    },
    {
      "entity": "transactions",
      "fields_used": "enrollment_id, amount_cents, paid_at",
      "purpose": "Transaction source"
    },
    {
      "entity": "payouts",
      "fields_used": "amount_cents, status, paid_at, approved_at",
      "purpose": "Payout records"
    },
    {
      "entity": "courses",
      "fields_used": "id, title",
      "purpose": "Course breakdown"
    },
    {
      "entity": "enrollments",
      "fields_used": "course_id",
      "purpose": "Link transactions to courses"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Page title: \"Earnings\"",
        "Period selector: This month / Last month / This year / All time"
      ]
    },
    {
      "title": "Earnings Summary Cards",
      "items": [
        "**Available Balance** - Ready for payout",
        "**Pending** - In escrow, not yet released",
        "**This Period** - Earned in selected period",
        "**Lifetime Earnings** - Total ever earned",
        "\"Request Payout\" button (if balance > threshold)"
      ]
    },
    {
      "title": "Revenue Chart",
      "items": [
        "Bar/line chart: Revenue over time",
        "Monthly or weekly granularity",
        "Stacked by course (optional)"
      ]
    },
    {
      "title": "Revenue by Course",
      "items": [
        "| Column | Content |\n|--------|---------|\n| Course | Title |\n| Enrollments | Count in period |\n| Gross Revenue | Total course revenue |\n| Your Royalty (15%) | Creator's share |\n| Status | Released / Pending |"
      ]
    },
    {
      "title": "Transaction History",
      "items": [
        "Expandable for full transaction details",
        "Filter by course, status, date range",
        "Pagination or infinite scroll"
      ]
    },
    {
      "title": "Payout History",
      "items": [
        "| Column | Content |\n|--------|---------|\n| Date | Payout date |\n| Amount | Payout amount |\n| Status | Processing / Completed / Failed |\n| Reference | Stripe transfer ID |"
      ]
    },
    {
      "title": "Pending Releases",
      "items": [
        "List of transactions still in escrow",
        "Expected release dates",
        "Conditions for release (student completion, time-based)"
      ]
    },
    {
      "title": "Payment Settings Summary",
      "items": [
        "Connected Stripe account status",
        "Payout threshold",
        "\"Update Settings\" → SETT"
      ]
    }
  ],
  "userStories": [
    "US-C035: View detailed earnings",
    "US-C050: Track revenue by course",
    "US-C051: View payout history",
    "US-C052: Request payouts"
  ],
  "statesVariations": [
    {
      "state": "Default",
      "description": "Current month earnings"
    },
    {
      "state": "Filtered",
      "description": "By date range or course"
    },
    {
      "state": "Has Balance",
      "description": "Payout button enabled"
    },
    {
      "state": "No Balance",
      "description": "Payout button disabled"
    },
    {
      "state": "Stripe Not Connected",
      "description": "Prompt to connect Stripe"
    },
    {
      "state": "Empty",
      "description": "No earnings yet"
    }
  ],
  "mobileConsiderations": [
    "Summary cards scroll horizontally",
    "Transaction list is primary view",
    "Charts simplified",
    "Payout action prominent"
  ],
  "errorHandling": [
    {
      "error": "Load fails",
      "display": "\"Unable to load earnings. [Retry]\""
    },
    {
      "error": "Payout request fails",
      "display": "\"Unable to process. Try again.\""
    },
    {
      "error": "Stripe disconnected",
      "display": "\"Reconnect your Stripe account\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "balance, period"
    },
    {
      "event": "`payout_requested`",
      "trigger": "Request clicked",
      "data": "amount"
    },
    {
      "event": "`period_changed`",
      "trigger": "Date range changed",
      "data": "new_period"
    },
    {
      "event": "`transaction_viewed`",
      "trigger": "Row expanded",
      "data": "transaction_id"
    }
  ],
  "notes": [
    "CD-020: Creator gets 15% royalty",
    "CD-033: 85/15 split (ST gets 85%, Creator gets 15% when ST teaches)",
    "Stripe Connect for payouts (Express accounts)",
    "Earnings come from payment_splits table",
    "Stripe dashboard link for detailed transaction info",
    "Consider tax documentation features (1099, future)"
  ],
