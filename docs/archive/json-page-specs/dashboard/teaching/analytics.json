{
  "metadata": {
    "title": "ST Analytics",
    "code": "TANA",
    "route": "/dashboard/teaching/analytics",
    "astroFile": "src/pages/dashboard/teaching/analytics.astro",
    "access": "StudentTeacher",
    "priority": "P1",
    "testScript": "scripts/page-tests/test-TANA.sh",
    "tsxComponents": [
      "src/components/analytics/STAnalytics.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "spec": "docs/pagespecs/dashboard/teaching/TANA.md"
    }
  },
  "purpose": "Provide Student-Teachers with performance analytics: earnings trends, session patterns, student completion metrics, and performance comparisons over time.",
  "connections": {
    "incoming": [
      {
        "source": "TDSH",
        "sourceRoute": "/dashboard/teaching",
        "trigger": "\"View Analytics\" link",
        "notes": "From ST dashboard stats section"
      },
      {
        "source": "CEAR",
        "sourceRoute": "/dashboard/teaching/earnings",
        "trigger": "\"View Trends\" link",
        "notes": "From earnings detail"
      },
      {
        "source": "Nav",
        "sourceRoute": "",
        "trigger": "\"Analytics\" link",
        "notes": "ST navigation"
      }
    ],
    "outgoing": [
      {
        "target": "CEAR",
        "targetRoute": "/dashboard/teaching/earnings",
        "trigger": "\"View Full Earnings\"",
        "notes": "To earnings detail"
      },
      {
        "target": "CSES",
        "targetRoute": "/dashboard/teaching/sessions",
        "trigger": "\"View Sessions\"",
        "notes": "To session history"
      },
      {
        "target": "CMST",
        "targetRoute": "/dashboard/teaching/students",
        "trigger": "\"View Students\"",
        "notes": "To student list"
      },
      {
        "target": "TDSH",
        "targetRoute": "/dashboard/teaching",
        "trigger": "Back/breadcrumb",
        "notes": "Return to dashboard"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "payment_splits",
      "fields_used": "amount_cents, created_at (where recipient_type = 'st')",
      "purpose": "Earnings time series"
    },
    {
      "entity": "video_sessions",
      "fields_used": "scheduled_at, status, actual_duration_minutes, rating",
      "purpose": "Session trends and metrics"
    },
    {
      "entity": "enrollments",
      "fields_used": "status, progress_percent, enrolled_at, completed_at",
      "purpose": "Student completion metrics"
    },
    {
      "entity": "student_teachers",
      "fields_used": "rating, rating_count, certified_at",
      "purpose": "ST profile metrics"
    },
    {
      "entity": "courses",
      "fields_used": "id, title",
      "purpose": "Course filter"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Page title: \"Analytics\"",
        "Period selector: 7 days / 30 days / 90 days / 1 year / All time",
        "Course filter dropdown (if ST teaches multiple courses)"
      ]
    },
    {
      "title": "Key Metrics Cards",
      "items": [
        "**Earnings** - Period earnings with % change",
        "**Sessions** - Sessions completed with % change",
        "**Students** - Active students count",
        "**Rating** - Average rating with trend"
      ]
    },
    {
      "title": "Earnings Trend Chart",
      "items": [
        "Line/area chart: Earnings over time",
        "Daily/weekly/monthly granularity based on period",
        "Tooltip with exact amounts"
      ]
    },
    {
      "title": "Sessions Trend Chart",
      "items": [
        "Line chart: Sessions over time",
        "Shows scheduled vs completed",
        "Cancellation rate indicator"
      ]
    },
    {
      "title": "Student Progress Distribution",
      "items": [
        "Pie/donut chart: Students by progress stage",
        "Segments: Not Started, 1-25%, 25-50%, 50-75%, 75-99%, Completed",
        "Click segment for student list (future)"
      ]
    },
    {
      "title": "Session Patterns",
      "items": [
        "Bar chart: Sessions by day of week",
        "Helps identify popular teaching times",
        "Average duration per day"
      ]
    },
    {
      "title": "Performance Summary",
      "items": [
        "Avg time student spends with you before completion",
        "Sessions per student average",
        "Completion rate (your students)",
        "Comparison to platform average (future)"
      ]
    }
  ],
  "userStories": [
    "US-ST-040: View teaching performance trends",
    "US-ST-041: Track earnings over time",
    "US-ST-042: Understand student progress patterns",
    "US-ST-043: Identify best teaching times"
  ],
  "statesVariations": [
    {
      "state": "Default",
      "description": "Last 30 days, all courses"
    },
    {
      "state": "Filtered",
      "description": "By period or specific course"
    },
    {
      "state": "New ST",
      "description": "Limited data message, encourage first sessions"
    },
    {
      "state": "Loading",
      "description": "Skeleton charts during data fetch"
    },
    {
      "state": "Error",
      "description": "Failed to load with retry option"
    }
  ],
  "mobileConsiderations": [
    "Metric cards in 2x2 grid",
    "Charts stack vertically",
    "Period selector as dropdown",
    "Simplified chart interactions"
  ],
  "errorHandling": [
    {
      "error": "Load fails",
      "display": "\"Unable to load analytics. [Retry]\""
    },
    {
      "error": "No data for period",
      "display": "\"No activity in this period. Try a longer range.\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "period, course_filter"
    },
    {
      "event": "`period_changed`",
      "trigger": "Period selector change",
      "data": "new_period"
    },
    {
      "event": "`course_filtered`",
      "trigger": "Course filter change",
      "data": "course_id"
    }
  ],
  "notes": [
    "Simpler than Creator Analytics (CANA) - S-Ts have fewer dimensions",
    "No S-T leaderboard (that's for creators viewing their S-Ts)",
    "Reuses chart components from CANA",
    "Consider adding goal-setting feature (future)",
    "Rating trend requires rating_history table (future)"
  ],
  "testCoverage": {
    "pageTest": {
      "file": "tests/pages/dashboard/teaching/analytics.test.tsx",
      "exists": false
    },
    "componentTest": {
      "file": "tests/components/teaching/STAnalytics.test.tsx",
      "exists": true
    },
    "apiTests": [
      {
        "endpoint": "GET /api/me/st-analytics",
        "testFile": "tests/api/me/st-analytics/index.test.ts",
        "tested": true
      },
      {
        "endpoint": "GET /api/me/st-analytics/earnings",
        "testFile": "tests/api/me/st-analytics/index.test.ts",
        "tested": true
      },
      {
        "endpoint": "GET /api/me/st-analytics/sessions",
        "testFile": "tests/api/me/st-analytics/index.test.ts",
        "tested": true
      },
      {
        "endpoint": "GET /api/me/st-analytics/students",
        "testFile": "tests/api/me/st-analytics/index.test.ts",
        "tested": true
      },
      {
        "endpoint": "(covered by earnings.test.ts)",
        "testFile": "tests/api/me/st-analytics/earnings.test.ts",
        "tested": true
      },
      {
        "endpoint": "(covered by sessions.test.ts)",
        "testFile": "tests/api/me/st-analytics/sessions.test.ts",
        "tested": true
      },
      {
        "endpoint": "(covered by students.test.ts)",
        "testFile": "tests/api/me/st-analytics/students.test.ts",
        "tested": true
      }
    ],
    "summary": {
      "pageTest": false,
      "componentTest": true,
      "apiCoverage": "7/7",
      "readyToWork": true
    }
  },
  "plannedApiCalls": []
}
