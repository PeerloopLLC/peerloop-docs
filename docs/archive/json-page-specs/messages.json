      {
        "target": "PROF",
        "targetRoute": "/profile",
        "trigger": "Avatar/name click in conversation",
        "notes": "View user's profile"
      },
      {
        "target": "STPR",
        "targetRoute": "/teachers/[handle]",
        "trigger": "Avatar/name click (if ST)",
        "notes": "View ST profile"
      },
      {
        "target": "SBOK",
        "targetRoute": "/courses/[slug]/book",
        "trigger": "\"Book Session\" in chat",
        "notes": "Schedule with ST"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "conversations",
      "fields_used": "id, updated_at",
      "purpose": "Conversation list"
    },
    {
      "entity": "conversation_participants",
      "fields_used": "conversation_id, user_id, last_read_at",
      "purpose": "Participants"
    },
    {
      "entity": "messages",
      "fields_used": "id, conversation_id, sender_id, content, created_at",
      "purpose": "Message content"
    },
    {
      "entity": "users",
      "fields_used": "id, name, avatar, handle",
      "purpose": "Participant display"
    }
  ],
  "sections": [
    {
      "title": "Conversation List (Left Panel / Main on Mobile)",
      "items": [
        "List of conversations sorted by most recent",
        "Each shows:",
        "Search conversations",
        "\"New Message\" button → start new conversation"
      ]
    },
    {
      "title": "Message Thread (Right Panel / Separate View on Mobile)",
      "items": [
        "**Header:**",
        "**Message List:**",
        "**Composer:**"
      ]
    },
    {
      "title": "New Conversation Modal/View",
      "items": [
        "Search for user by name or handle",
        "Select from recent/suggested users",
        "Start typing message"
      ]
    },
    {
      "title": "Empty States",
      "items": [
        "No conversations: \"No messages yet. Start a conversation!\"",
        "No messages in thread: \"Start the conversation\""
      ]
    }
  ],
  "userStories": [
    "US-P004: Private messaging system",
    "US-S016: Send private messages to STs",
    "US-S017: Receive messages from teachers",
    "US-S018: Access message history",
    "US-S019: Get notifications for new messages"
  ],
  "statesVariations": [
    {
      "state": "Empty",
      "description": "No conversations, show CTA"
    },
    {
      "state": "List View",
      "description": "Browsing conversations"
    },
    {
      "state": "Thread View",
      "description": "Reading/writing in conversation"
    },
    {
      "state": "New Message",
      "description": "Starting new conversation"
    },
    {
      "state": "Unread",
      "description": "Conversations with unread messages highlighted"
    }
  ],
  "mobileConsiderations": [
    "List and thread are separate screens",
    "Back button to return to list",
    "Keyboard-aware composer (stays above keyboard)",
    "Swipe to archive/delete (future)"
  ],
  "errorHandling": [
    {
      "error": "Load fails",
      "display": "\"Unable to load messages. [Retry]\""
    },
    {
      "error": "Send fails",
      "display": "\"Message not sent. [Retry]\" with failed indicator"
    },
    {
      "error": "User not found",
      "display": "\"User not found\" in search"
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "conversations_count"
    },
    {
      "event": "`conversation_opened`",
      "trigger": "Thread opened",
      "data": "conversation_id"
    },
    {
      "event": "`message_sent`",
      "trigger": "Message sent",
      "data": "conversation_id, is_new_conversation"
    },
    {
      "event": "`new_conversation`",
      "trigger": "Started new conversation",
      "data": "recipient_id"
    }
  ],
  "notes": [
    "Using custom WebSocket for real-time message delivery",
