        "notes": "Global navigation"
      },
      {
        "source": "STPR",
        "sourceRoute": "/teachers/[handle]",
        "trigger": "\"Message\" button",
        "notes": "Message an ST"
      },
      {
        "source": "CPRO",
        "sourceRoute": "/creators/[handle]",
        "trigger": "\"Message\" button",
        "notes": "Message a creator"
      },
      {
        "source": "PROF",
        "sourceRoute": "/profile",
        "trigger": "\"Message\" button",
        "notes": "Message any user"
      },
      {
        "source": "SDSH",
        "sourceRoute": "/dashboard/learning",
        "trigger": "\"Message Teacher\"",
        "notes": "Contact assigned ST"
      },
      {
        "source": "TDSH",
        "sourceRoute": "/dashboard/teaching",
        "trigger": "\"Message Student\"",
        "notes": "Contact a student"
