{
  "metadata": {
    "title": "Course Discussion",
    "code": "CDIS",
    "route": "/courses/[slug]/discuss",
    "astroFile": "src/pages/courses/[slug]/discuss.astro",
    "access": "Authenticated",
    "priority": "P2",
    "testScript": "scripts/page-tests/test-CDIS.sh",
    "tsxComponents": [
      "src/components/community/CourseFeed.tsx"
    ],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/CDIS/CDIS.md",
      "spec": "docs/pagespecs/courses/CDIS.md"
    }
  },
  "purpose": "Course-specific community chat room where enrolled students can ask questions, get help from STs, and award goodwill points for helpful answers.",
  "connections": {
    "incoming": [
      {
        "source": "CCNT",
        "sourceRoute": "/courses/[slug]/learn",
        "trigger": "\"Course Chat\" link",
        "notes": "From course content"
      },
      {
        "source": "CDET",
        "sourceRoute": "/courses/[slug]",
        "trigger": "\"Join Discussion\"",
        "notes": "From course detail"
      },
      {
        "source": "NOTF",
        "sourceRoute": "/notifications",
        "trigger": "Chat notification",
        "notes": "New message/mention"
      },
      {
        "source": "SDSH",
        "sourceRoute": "/dashboard/learning",
        "trigger": "Course chat icon",
        "notes": "Quick access"
      }
    ],
    "outgoing": [
      {
        "target": "CCNT",
        "targetRoute": "/courses/[slug]/learn",
        "trigger": "\"Back to Course\"",
        "notes": "Return to content"
      },
      {
        "target": "STPR",
        "targetRoute": "/teachers/[handle]",
        "trigger": "ST name click",
        "notes": "View helper's profile"
      },
      {
        "target": "PROF",
        "targetRoute": "/profile",
        "trigger": "User name click",
        "notes": "View user's profile"
      },
      {
        "target": "HELP",
        "targetRoute": "/help",
        "trigger": "\"Need 1-on-1 Help?\"",
        "notes": "Escalate to Summon"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "posts",
      "fields_used": "id, author_id, course_id, content, created_at",
      "purpose": "Chat messages"
    },
    {
      "entity": "users",
      "fields_used": "id, name, avatar, is_student_teacher",
      "purpose": "Participant info"
    },
    {
      "entity": "student_teachers",
      "fields_used": "course_id, user_id",
      "purpose": "ST badge display"
    },
    {
      "entity": "user_goodwill",
      "fields_used": "balance",
      "purpose": "Points available to award"
    },
    {
      "entity": "goodwill_transactions",
      "fields_used": "from_user_id, to_user_id, points, reason",
      "purpose": "Awards"
    },
    {
      "entity": "courses",
      "fields_used": "id, title",
      "purpose": "Course context"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Course title + \"Chat\"",
        "Participants count: \"X online\"",
        "\"Back to Course\" → CCNT",
        "Room settings (mute, etc.)"
      ]
    },
    {
      "title": "Chat Messages (Main Area)",
      "items": [
        "Real-time message stream",
        "Each message shows:",
        "Question messages highlighted differently",
        "Answers to questions indented/grouped"
      ]
    },
    {
      "title": "Help Queue Panel (Sidebar or Tab)",
      "items": [
        "**Pending Questions:**",
        "**Available Helpers:**"
      ]
    },
    {
      "title": "Message Composer",
      "items": [
        "Text input",
        "\"Ask Question\" toggle (marks as question)",
        "Send button",
        "Character limit indicator"
      ]
    },
    {
      "title": "\"This Helped!\" Interaction",
      "items": [
        "On clicking \"This Helped!\":"
      ]
    },
    {
      "title": "Goodwill Points Indicator",
      "items": [
        "User's available balance shown",
        "\"X points to give\"",
        "Link to earn more"
      ]
    }
  ],
  "userStories": [
    "US-S065: Participate in course chat",
    "US-S066: Ask questions in chat",
    "US-T028: ST answers questions in chat",
    "US-S069: Award points for helpful answers (from CD-023)"
  ],
  "statesVariations": [
    {
      "state": "Active",
      "description": "Messages flowing, users online"
    },
    {
      "state": "Quiet",
      "description": "No recent messages, \"Start the conversation\" prompt"
    },
    {
      "state": "Question Pending",
      "description": "User's question awaiting answer"
    },
    {
      "state": "Helping",
      "description": "ST actively answering questions"
    },
    {
      "state": "Low Balance",
      "description": "User has few points to award, subtle prompt to help others"
    }
  ],
  "mobileConsiderations": [
    "Full-screen chat",
    "Help queue accessed via tab or swipe",
    "Composer sticky at bottom",
    "Quick point award via long-press"
  ],
  "errorHandling": [
    {
      "error": "Not authorized",
      "display": "\"You must be enrolled to access this chat.\""
    },
    {
      "error": "Send fails",
      "display": "\"Message not sent. [Retry]\""
    },
    {
      "error": "Award fails",
      "display": "\"Unable to award points. Try again.\""
    },
    {
      "error": "Connection lost",
      "display": "\"Reconnecting...\" with retry"
    }
  ],
  "analyticsEvents": [
    {
      "event": "`page_view`",
      "trigger": "Page load",
      "data": "course_id, user_role"
    },
    {
      "event": "`message_sent`",
      "trigger": "Message sent",
      "data": "course_id, is_question"
    },
    {
      "event": "`question_asked`",
      "trigger": "Question marked",
      "data": "course_id"
    },
    {
      "event": "`points_awarded`",
      "trigger": "\"This Helped\" completed",
      "data": "points, recipient_id"
    },
    {
      "event": "`helper_online`",
      "trigger": "ST came online",
      "data": "st_id, course_id"
    }
  ],
  "notes": [
    "**Feature Flag:** `course_chat` - check with `canAccess('course_chat')`",
    "**Block 2+ feature:** Part of Goodwill Points system (CD-023)",
    "Custom WebSocket via Cloudflare Durable Objects (not Stream Chat)",
    "Consider anti-spam: rate limits (1 msg/sec), moderation",
    "ST incentive: Earning points for helping",
    "Integration with MODQ for flagged content",
    "Message history persisted in chat_messages table"
  ],
  "plannedApiCalls": [],
  "testCoverage": {
    "pageTest": {
      "file": "tests/pages/courses/[slug]/discuss.test.tsx",
      "exists": false
    },
    "componentTest": {
      "file": "tests/components/community/CourseFeed.test.tsx",
      "exists": true
    },
    "ssrTest": {
      "file": "tests/ssr/courses.test.ts",
      "loader": "fetchCourseDiscussionData",
      "exists": true
    },
    "apiTests": [
      {
        "endpoint": "(covered by [slug].test.ts)",
        "testFile": "tests/api/feeds/course/[slug].test.ts",
        "tested": true
      },
      {
        "endpoint": "GET /api/feeds/course/[slug]",
        "tested": false
      },
      {
        "endpoint": "POST /api/feeds/course/[slug]",
        "tested": false
      }
    ],
    "summary": {
      "pageTest": false,
      "componentTest": true,
      "ssrTest": true,
      "apiCoverage": "1/3",
      "readyToWork": true
    }
  }
}
