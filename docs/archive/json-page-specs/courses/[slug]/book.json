  "plannedApiCalls": [
    {
      "endpoint": "GET /api/users?role=student_teacher&courseId={courseId}",
      "when": "Page load (Step 1: Select ST)",
      "purpose": "List available STs certified for this specific course",
      "notes": "Response shape matches UserCardCompactData. Use courseId from the course being booked. Returns only active STs (is_active=1) for this course."
    },
    {
      "endpoint": "GET /api/student-teachers/{stId}/availability?date={date}",
      "when": "Step 2: Select Date/Time",
      "purpose": "Get available time slots for selected ST"
    },
    {
      "endpoint": "POST /api/sessions",
      "when": "Step 4: Confirm booking",
      "purpose": "Create the session booking"
    }
