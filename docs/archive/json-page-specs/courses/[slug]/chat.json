  "plannedApiCalls": [
    {
      "endpoint": "GET /api/courses/:slug/chat/history",
      "when": "Page load",
      "purpose": "Recent messages"
    },
    {
      "endpoint": "WS /api/courses/:slug/chat",
      "when": "Real-time",
      "purpose": "WebSocket for live chat"
    },
    {
      "endpoint": "POST /api/chat/messages",
      "when": "Send message",
      "purpose": "Persist message (fallback)"
    },
    {
      "endpoint": "POST /api/chat/messages/:id/report",
      "when": "Report click",
      "purpose": "Flag for moderation"
    }
  ]
