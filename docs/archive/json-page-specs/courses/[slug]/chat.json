  "statesVariations": [
    {
      "state": "Active",
      "description": "Connected with live messages"
    },
    {
      "state": "Connecting",
      "description": "WebSocket establishing"
    },
    {
      "state": "Disconnected",
      "description": "Connection lost, retry UI"
    },
    {
      "state": "Empty",
      "description": "No messages yet"
    },
    {
      "state": "Loading History",
      "description": "Fetching older messages"
    }
  ],
  "mobileConsiderations": [
    "Full-screen chat on mobile",
    "Participants in bottom sheet",
    "Keyboard-aware input positioning",
    "Touch-friendly emoji picker"
  ],
  "errorHandling": [
    {
      "error": "Not enrolled",
      "display": "\"Enroll in this course to join the chat.\" → CDET"
    },
    {
      "error": "Connection lost",
      "display": "\"Reconnecting...\" with retry"
    },
    {
      "error": "Send fails",
      "display": "\"Message failed to send. [Retry]\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "chat_joined",
      "trigger": "Page load",
      "data": "course_id, user_id"
    },
    {
      "event": "message_sent",
      "trigger": "Send message",
      "data": "course_id, message_length"
    }
  ],
  "notes": [
    "Block 2+ goodwill feature",
    "WebSocket via Cloudflare Durable Objects",
    "Fallback to polling if WS unavailable",
    "S-Ts and Creators have moderation powers",
    "Consider Stream.io chat as alternative to custom implementation"
  ],
