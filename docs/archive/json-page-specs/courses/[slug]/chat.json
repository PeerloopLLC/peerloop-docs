{
  "metadata": {
    "title": "Course Chat",
    "code": "CHAT",
    "route": "/courses/:slug/chat",
    "astroFile": "src/pages/courses/[slug]/chat.astro",
    "access": "Authenticated",
    "priority": "P2",
    "tsxComponents": [],
    "astroComponents": [],
    "docs": {
      "spec": "docs/pagespecs/courses/CHAT.md"
    }
  },
  "purpose": "Real-time chat room for course enrollees to discuss content, ask questions, and build community with fellow students and their assigned Student-Teachers.",
  "connections": {
    "incoming": [
      {
        "source": "CCNT",
        "sourceRoute": "/courses/:slug/learn",
        "trigger": "\"Course Chat\" link",
        "notes": "From learning page"
      },
      {
        "source": "CDET",
        "sourceRoute": "/courses/:slug",
        "trigger": "\"Join Discussion\" button",
        "notes": "Enrolled students only"
      },
      {
        "source": "CDIS",
        "sourceRoute": "/courses/:slug/discuss",
        "trigger": "\"Live Chat\" tab",
        "notes": "From discussion forum"
      }
    ],
    "outgoing": [
      {
        "target": "CCNT",
        "targetRoute": "/courses/:slug/learn",
        "trigger": "\"Back to Course\" link",
        "notes": "Return to content"
      },
      {
        "target": "PROF",
        "targetRoute": "/@:handle",
        "trigger": "User avatar click",
        "notes": "View participant profile"
      },
      {
        "target": "STPR",
        "targetRoute": "/teachers/:handle",
        "trigger": "S-T badge click",
        "notes": "View S-T profile"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "courses",
      "fields_used": "id, title, slug",
      "purpose": "Course context"
    },
    {
      "entity": "enrollments",
      "fields_used": "user_id, course_id",
      "purpose": "Verify enrollment"
    },
    {
      "entity": "chat_messages",
      "fields_used": "id, course_id, user_id, content, created_at, is_pinned",
      "purpose": "Chat history"
    },
    {
      "entity": "users",
      "fields_used": "id, name, avatar_url, roles",
      "purpose": "Participant info"
    },
    {
      "entity": "student_teachers",
      "fields_used": "user_id, course_id, is_active",
      "purpose": "Identify S-Ts in chat"
    }
  ],
