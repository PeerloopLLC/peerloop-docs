        "source": "SROM",
        "sourceRoute": "/session/[id]",
        "trigger": "\"Back to Course\"",
        "notes": "After session"
      },
      {
        "source": "NOTF",
        "sourceRoute": "/notifications",
        "trigger": "Course update notification",
        "notes": "Content updates"
      }
    ],
    "outgoing": [
      {
        "target": "SBOK",
        "targetRoute": "/courses/[slug]/book",
        "trigger": "\"Schedule Session\"",
        "notes": "Book tutoring session"
      },
      {
        "target": "SROM",
        "targetRoute": "/session/[id]",
        "trigger": "\"Join Session\" (if imminent)",
        "notes": "Active session"
      },
      {
        "target": "SDSH",
        "targetRoute": "/dashboard/learning",
        "trigger": "\"Dashboard\" / back",
        "notes": "Return to dashboard"
      },
      {
        "target": "CDET",
        "targetRoute": "/courses/[slug]",
        "trigger": "\"Course Info\"",
        "notes": "View course details"
      },
      {
        "target": "CHAT",
        "targetRoute": "/courses/[slug]/discuss",
        "trigger": "\"Course Chat\" (Block 2+)",
        "notes": "Course community chat"
      },
      {
        "target": "HELP",
        "targetRoute": "/help",
        "trigger": "\"Summon Help\" button (Block 2+)",
        "notes": "Request help from ST"
      },
      {
        "target": "STPR",
        "targetRoute": "/teachers/[handle]",
        "trigger": "ST name in \"Your Teacher\"",
        "notes": "View assigned ST"
      }
    ]
  },
