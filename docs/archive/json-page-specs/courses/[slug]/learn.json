        "trigger": "\"Continue Learning\"",
        "notes": "From dashboard"
      },
      {
        "source": "CDET",
        "sourceRoute": "/courses/[slug]",
        "trigger": "\"Start Learning\" (enrolled)",
        "notes": "From course detail"
