      "data": "filters_applied, search_query"
    },
    {
      "event": "search",
      "trigger": "Search submitted",
      "data": "query, results_count"
    },
    {
      "event": "filter_applied",
      "trigger": "Filter changed",
      "data": "filter_type, filter_value"
    },
    {
      "event": "course_card_click",
      "trigger": "Course clicked",
      "data": "course_id, position, filters_active"
    },
    {
      "event": "sort_changed",
      "trigger": "Sort option changed",
      "data": "sort_option"
    }
  ],
  "notes": [
