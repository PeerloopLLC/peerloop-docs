        "sourceRoute": "/creators/[handle]",
        "trigger": "\"View Courses\" on creator profile",
        "notes": "Filtered by creator"
      },
      {
        "source": "Nav",
        "trigger": "\"Courses\" nav link",
        "notes": "Global navigation"
      },
      {
        "source": "(External)",
        "trigger": "Direct URL, search",
        "notes": "/courses or /courses?q=..."
      }
