        "source": "HOME",
        "sourceRoute": "/",
        "trigger": "\"View All Courses\" link",
        "notes": "From featured section"
      },
      {
        "source": "CDET",
        "sourceRoute": "/courses/[slug]",
        "trigger": "Back/breadcrumb",
        "notes": "Return from course detail"
      },
