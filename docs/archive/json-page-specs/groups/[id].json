{
  "metadata": {
    "title": "Sub-Community",
    "code": "SUBCOM",
    "route": "/groups/[id]",
    "astroFile": "src/pages/groups/[id].astro",
    "access": "Authenticated",
    "priority": "P3",
    "tsxComponents": [],
    "astroComponents": [],
    "docs": {
      "page": "docs/pages/SUBCOM/SUBCOM.md",
      "spec": "docs/pagespecs/groups/SUBCOM.md"
    }
  },
  "purpose": "User-created sub-communities for study groups, interest clusters, or private collaboration spaces within the platform.",
  "connections": {
    "incoming": [
      {
        "source": "FEED",
        "sourceRoute": "/community",
        "trigger": "Sub-community card/link",
        "notes": "From main feed"
      },
      {
        "source": "SDSH",
        "sourceRoute": "/dashboard/learning",
        "trigger": "\"My Communities\" section",
        "notes": "Dashboard widget"
      },
      {
        "source": "NOTF",
        "sourceRoute": "/notifications",
        "trigger": "Community notification",
        "notes": "Invited to join"
      },
      {
        "source": "(Direct)",
        "sourceRoute": "",
        "trigger": "Shared invite link",
        "notes": "External share"
      }
    ],
    "outgoing": [
      {
        "target": "STPR",
        "targetRoute": "/teachers/[handle]",
        "trigger": "Click member name",
        "notes": "View member profile"
      },
      {
        "target": "FEED",
        "targetRoute": "/community",
        "trigger": "Back/breadcrumb",
        "notes": "Return to main feed"
      },
      {
        "target": "MSGS",
        "targetRoute": "/messages",
        "trigger": "\"Message\" button",
        "notes": "DM a member"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "sub_communities",
      "fields_used": "id, name, slug, description, visibility, creator_id",
      "purpose": "Community info"
    },
    {
      "entity": "sub_community_members",
      "fields_used": "user_id, community_id, role, joined_at",
      "purpose": "Membership"
    },
    {
      "entity": "sub_community_posts",
      "fields_used": "id, content, author_id, created_at",
      "purpose": "Community feed"
    },
    {
      "entity": "sub_community_invites",
      "fields_used": "email, token, status",
      "purpose": "Pending invites"
    }
  ],
  "sections": [
    {
      "title": "Header",
      "items": [
        "Community name + description",
        "Member count",
        "Join/Leave button (or \"Pending\" if invite-only)",
        "Settings gear (for owner/admins)"
      ]
    },
    {
      "title": "Community Feed",
      "items": [
        "Posts from members only",
        "Same feed UI as main FEED (cards, reactions, comments)",
        "\"New Post\" composer"
      ]
    },
    {
      "title": "Members Sidebar (Desktop) / Tab (Mobile)",
      "items": [
        "Member list with avatars",
        "Owner/Admin badges",
        "\"Invite Members\" button (if permitted)"
      ]
    },
    {
      "title": "Settings Panel (Owner/Admin only)",
      "items": [
        "Edit name/description",
        "Visibility toggle (Public/Invite-only)",
        "Manage members (remove, promote to admin)",
        "Invite settings (who can invite)",
        "Delete community"
      ]
    },
    {
      "title": "Invite Flow",
      "items": [
        "Search users by name/email",
        "Send invite (creates notification)",
        "Pending invites list",
        "Invite link generation"
      ]
    }
  ],
  "userStories": [
    "US-S081: As a Student, I need to create a sub-community and invite specific users so that I can form study groups or interest clusters",
    "US-P097: As a System, I need to support user-created sub-communities with invite functionality so that users can organize privately"
  ],
  "statesVariations": [
    {
      "state": "Member View",
      "description": "Full access to feed and members"
    },
    {
      "state": "Non-Member (Public)",
      "description": "Can see feed, join button visible"
    },
    {
      "state": "Non-Member (Private)",
      "description": "\"Request to Join\" or \"Invite Only\" message"
    },
    {
      "state": "Owner View",
      "description": "Full access + settings panel"
    },
    {
      "state": "Empty",
      "description": "No posts yet - prompt to start conversation"
    }
  ],
  "mobileConsiderations": [
    "Members list as bottom sheet or separate tab",
    "Settings accessed via menu",
    "Invite flow as modal"
  ],
  "errorHandling": [
    {
      "error": "Load fails",
      "display": "\"Unable to load community. [Retry]\""
    },
    {
      "error": "Not found",
      "display": "\"This community doesn't exist or is private\""
    },
    {
      "error": "Already member",
      "display": "\"You're already a member\""
    },
    {
      "error": "Invite expired",
      "display": "\"This invite has expired\""
    }
  ],
  "analyticsEvents": [
    {
      "event": "sub_community_viewed",
      "trigger": "Page load",
      "data": "group_id"
    },
    {
      "event": "sub_community_joined",
      "trigger": "User joins",
      "data": "group_id, user_id"
    },
    {
      "event": "sub_community_post_created",
      "trigger": "New post",
      "data": "group_id, post_type"
    },
    {
      "event": "sub_community_member_invited",
      "trigger": "Invite sent",
      "data": "group_id, invitee_id"
    }
  ],
  "notes": [
    "**Feature Flag:** `sub_communities` - check with `canAccess('sub_communities')`",
    "**Dependencies:** Requires `community_feed` feature enabled",
    "Uses Stream.io `subcommunity` feed group (separate from main feeds)",
    "Consider limits: max communities per user (5), max members (100)",
    "Moderation: Platform moderators access via MODQ",
    "Sub-community posts do NOT appear in main feed (isolated)",
    "CD-032 source: Fraser Meeting Notes mention study groups"
  ],
  "plannedApiCalls": []
}
