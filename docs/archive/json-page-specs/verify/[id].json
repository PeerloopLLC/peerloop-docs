{
  "metadata": {
    "title": "Certificate Verify",
    "code": "CVER",
    "route": "/verify/:id",
    "astroFile": "src/pages/verify/[id].astro",
    "access": "Public",
    "priority": "P1",
    "testScript": "scripts/page-tests/test-CVER.sh",
    "tsxComponents": [],
    "astroComponents": [],
    "docs": {
      "spec": "docs/pagespecs/CVER.md"
    }
  },
  "purpose": "Public verification page for Peerloop certificates. Allows anyone to verify a certificate's authenticity by ID or QR code scan.",
  "connections": {
    "incoming": [
      {
        "source": "External",
        "sourceRoute": "",
        "trigger": "QR code scan",
        "notes": "From printed/shared certificate"
      },
      {
        "source": "External",
        "sourceRoute": "",
        "trigger": "Direct link",
        "notes": "Shared via email/social"
      },
      {
        "source": "ACRT",
        "sourceRoute": "/admin/certificates",
        "trigger": "\"Verify\" action",
        "notes": "Admin verification"
      }
    ],
    "outgoing": [
      {
        "target": "CDET",
        "targetRoute": "/courses/:slug",
        "trigger": "Course name link",
        "notes": "View course"
      },
      {
        "target": "CPRO",
        "targetRoute": "/creators/:handle",
        "trigger": "Creator name link",
        "notes": "View creator"
      },
      {
        "target": "PROF",
        "targetRoute": "/@:handle",
        "trigger": "Certificate holder name",
        "notes": "View holder profile"
      }
    ]
  },
  "dataRequirements": [
    {
      "entity": "certificates",
      "fields_used": "id, user_id, course_id, issued_at, certificate_number, status, revoked_at, revoked_reason",
      "purpose": "Certificate data"
    },
    {
      "entity": "users",
      "fields_used": "name, handle, avatar_url",
      "purpose": "Certificate holder"
    },
    {
      "entity": "courses",
      "fields_used": "title, slug, thumbnail_url",
      "purpose": "Course info"
    },
    {
      "entity": "users (creator)",
      "fields_used": "name, handle",
      "purpose": "Course creator"
    }
  ],
