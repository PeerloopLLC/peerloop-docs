{
  "env": {
    "TEST_ENV_VAR": "CANARY_VALUE_12345"
  },
  "permissions": {
    "allow": [
      "Read(/.claude/**)",
      "Read(/docs/**)",
      "Read(/research/**)",
      "Read(/RFC/**)",
      "Read(//tmp/timecard*)",
      "Edit(/.claude/**)",
      "Edit(/docs/**)",
      "Edit(/research/**)",
      "Edit(/RFC/**)",
      "Edit(//tmp/timecard*)",
      "Write(/.claude/**)",
      "Write(//tmp/timecard*)",
      "Bash(.claude/scripts/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-lint-tz.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-output-reminder.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/persist-project-dir.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/dual-repo-info.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/../Peerloop/scripts/check-env.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/tech-doc-drift.sh"
          }
        ]
      }
    ]
  }
}
