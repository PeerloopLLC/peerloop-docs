{
  "permissions": {
    "allow": [
      "Read(/.claude/**)",
      "Read(/docs/**)",
      "Read(//tmp/**)",
      "Read(//private/tmp/**)",
      "Edit(/.claude/**)",
      "Edit(/docs/**)",
      "Edit(//tmp/timecard*)",
      "Write(/.claude/**)",
      "Write(/docs/**)",
      "Write(//tmp/timecard*)",

      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(cat:*)",
      "Bash(sed:*)",
      "Bash(tr:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(diff:*)",
      "Bash(date:*)",
      "Bash(stat:*)",
      "Bash(hostname:*)",
      "Bash(awk:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(jq:*)",
      "Bash(chmod +x:*)",
      "Bash(tee /tmp/*)",

      "Bash(git:*)",
      "Bash(gh:*)",

      "Bash(node .claude/scripts/*)",
      "Bash(node ../Peerloop/scripts/*)",
      "Bash(node scripts/*)",
      "Bash(node /tmp/*)",
      "Bash(npx tsx .claude/scripts/*)",
      "Bash(npx tsx ../Peerloop/scripts/*)",
      "Bash(npx tsx scripts/*)",
      "Bash(npx tsx /tmp/*)",
      "Bash(python3 .claude/scripts/*)",
      "Bash(python3 /tmp/*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm ls:*)",
      "Bash(npm outdated:*)",
      "Bash(npm view:*)",
      "Bash(npm audit:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright:*)",
      "Bash(npx astro:*)",
      "Bash(npx eslint:*)",
      "Bash(npx wrangler:*)",
      "Bash(npx kill-port:*)",
      "Bash(wrangler:*)",

      "Bash(.claude/scripts/*)",
      "Bash(~/projects/peerloop-docs/.claude/scripts/*)",

      "Skill(r-start:*)",
      "Skill(r-end)",
      "Skill(r-commit)",
      "Skill(w-codecheck)",
      "Skill(w-sync-skills)",

      "WebSearch",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:astro.build)",
      "WebFetch(domain:docs.astro.build)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:blog.cloudflare.com)",
      "WebFetch(domain:docs.bigbluebutton.org)",
      "WebFetch(domain:support.bigbluebutton.org)",
      "WebFetch(domain:docs.stripe.com)",
      "WebFetch(domain:devblogs.microsoft.com)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push --force:*)",
      "Bash(git push -f)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -fx:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fd)",
      "Bash(git clean -fx)",
      "Bash(git clean -fdx)",
      "Bash(git checkout --:*)",
      "Bash(git branch -D:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-commit-lint-tz.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-output-reminder.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/persist-project-dir.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/dual-repo-info.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/../Peerloop/scripts/check-env.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/tech-doc-drift.sh"
          }
        ]
      }
    ]
  }
}
