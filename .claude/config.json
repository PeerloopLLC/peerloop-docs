{
  "codeRepo": "../Peerloop",

  "terminology": {
    "stage": "Block",
    "subStage": "Section",
    "stageFormat": "CODE",
    "subStageFormat": "BLOCK.SECTION"
  },

  "features": {
    "apis": { "enabled": true, "location": "../Peerloop/src/pages/api/" },
    "tests": { "enabled": true, "location": "../Peerloop/tests/" },
    "cliScripts": { "enabled": true },
    "database": { "enabled": true, "type": "D1" },
    "tailwind": { "enabled": true, "version": 4 }
  },

  "paths": {
    "sessions": "docs/sessions/",
    "referenceDocs": "docs/reference/",
    "vendorDocs": "docs/reference/",
    "architectureDocs": "docs/as-designed/",
    "claudeOffload": "docs/reference/CLAUDE-OFFLOAD.md"
  },

  "thresholds": {
    "claudeMd": { "low": 150, "high": 250, "floor": 100 }
  },

  "astro": {
    "version": "6.x",
    "adapter": "cloudflare",
    "islands": true
  },

  "cloudflare": {
    "pages": true,
    "d1": true,
    "r2": true,
    "kv": true,
    "workers": false
  },

  "github": {
    "mainBranch": "main",
    "devBranchPattern": "jfg-dev-*"
  },

  "billing": {
    "currentCode": "Block-09"
  },

  "editor": "code",

  "commitTags": [
    "API",
    "Page",
    "Role",
    "Infra",
    "Doc",
    "DB",
    "Test",
    "User-facing",
    "Admin-facing"
  ],

  "rEnd": {
    "_comment": "Per-agent model selection for /r-end Step 3 dispatch. Enum matches the Agent tool's model parameter: sonnet | opus | haiku. Omit a field to inherit the main context model.",
    "agentModels": {
      "learnDecide": "opus",
      "updatePlan": "haiku",
      "docs": "sonnet"
    }
  },

  "rTimecardDay": {
    "dayWindow": {
      "overflowCapHHMM": "22:00",
      "roundToMinutes": 5
    },
    "convMeta": {
      "heartbeatPattern": "^Conv (\\d{3}) start —",
      "convPrefixPattern": "^Conv (\\d{3})[:\\s]"
    },
    "commitTagPrefixes": {
      "userFacing": "User-facing:",
      "adminFacing": "Admin-facing:",
      "api": "API:",
      "page": "Page:",
      "role": "Role:",
      "infra": "Infra:",
      "doc": "Doc:",
      "db": "DB:",
      "test": "Test:"
    },
    "legacy": {
      "bulletSectionHeaders": ["Changes:", "Fixes:", "Tests:"]
    },
    "render": {
      "tagPattern": "^\\[([^\\]]+)\\]",
      "countPattern": "\\b\\d+[-\\s]\\w+",
      "verbTagPattern": "^(?:Fixed|New|Added|Removed|Updated|Delete|Deleted|Remove)\\s+\\[([A-Z][\\w-]*)\\]"
    },
    "docPaths": ["docs/"],
    "docPathsExclude": ["docs/sessions/"],
    "docNameWhitelist": [
      "API-ENROLLMENTS", "API-REFERENCE", "API-AUTH", "API-COMMUNITY",
      "CLI-QUICKREF", "CLI-REFERENCE", "CLI-TESTING", "CLI-MISC",
      "DB-API", "DB-GUIDE", "REMOTE-API",
      "TEST-COVERAGE", "DEVELOPMENT-GUIDE", "BROWSER-TESTING", "SCRIPTS",
      "ROLES", "GLOSSARY", "POLICIES",
      "DECISIONS", "DOC-DECISIONS", "PLAN"
    ],
    "docRootExclude": [
      ".timecard.md",
      "COMPLETED_PLAN.md",
      "RESUME-STATE.md",
      "TIMELINE.md",
      "DECISIONS.md",
      "CONV-INDEX.md",
      "SESSION-INDEX.md"
    ],
    "routineStrip": {
      "phrases": [
        "session docs",
        "session logs",
        "Docs refreshed:",
        "Doc sync:",
        "synced",
        "/r-start",
        "/r-end",
        "/r-commit",
        "RESUME-STATE",
        "Session: Extract",
        "Session: Learnings",
        "Extract/Learnings/Decisions for Conv",
        "archive entry",
        "COMPLETED_PLAN.md",
        "marked complete",
        "marked done"
      ],
      "pathPatterns": ["docs/sessions/"],
      "countFiles": [
        "PLAN.md",
        "DECISIONS.md",
        "RESUME-STATE.md",
        "TIMELINE.md",
        "DOC-DECISIONS.md",
        "COMPLETED_PLAN.md",
        "CONV-INDEX.md"
      ],
      "countSkipIfContains": ["test", "suite"],
      "multiDocMinCount": 3,
      "stripIfTextEquals": ["none"],
      "stripDocTagWithoutDocMention": true
    },
    "testing": {
      "pathPrefixes": ["tests/"],
      "tagContains": ["Test"],
      "wordMatches": ["test", "tests", "testing", "suite", "spec"]
    },
    "reroute": {
      "infraPrefixes": [
        ".claude/skills/",
        ".claude/scripts/",
        ".claude/",
        "scripts/"
      ],
      "infraGroupLabels": {
        ".claude/skills/": "Skills",
        ".claude/scripts/": "Scripts",
        ".claude/": ".claude/",
        "scripts/": "Scripts",
        "db:migrate:": "Scripts",
        "db:reset:": "Scripts",
        "db:seed:": "Scripts",
        "db:setup:": "Scripts",
        "npm run ": "Scripts",
        "npx ": "Scripts"
      },
      "infraPrefixWords": [
        "db:migrate:", "db:reset:", "db:seed:", "db:setup:", "npm run ", "npx "
      ],
      "apiMethodRe": "\\b(GET|POST|PUT|PATCH|DELETE)\\s+/",
      "apiPathRe": "/api/[a-zA-Z0-9_]",
      "slashSkillRe": "(?:^|\\s)/([a-z]+-[a-z0-9-]+)\\b",
      "codePrefixRe": "(src/[a-zA-Z0-9_-]+)/",
      "dbPathPrefixes": ["migrations/", "migrations-dev/"],
      "dbBulletPrefixWords": ["Schema:", "Seed:", "Migration:"],
      "dbSqlRe": "\\b(LEFT\\s+JOIN|INNER\\s+JOIN|SELECT\\s+\\w+|ALTER\\s+TABLE|CREATE\\s+TABLE|DROP\\s+TABLE|INSERT\\s+INTO)\\b"
    },
    "mergeBlockPattern": "^([A-Z][A-Z0-9-]+)\\.",
    "skipFilter": {
      "anyOf": [
        { "isRoutine": true },
        { "docsMentionGte": "routineStrip.multiDocMinCount" },
        { "src": "doc", "docsMentionEq": 0, "flag": "routineStrip.stripDocTagWithoutDocMention" }
      ]
    },
    "h4Sections": [
      {
        "id": "userFacing",
        "title": "User-facing",
        "include": { "src": "userFacing" },
        "h5Strategy": "emDashOrFirstWord"
      },
      {
        "id": "adminFacing",
        "title": "Admin-facing",
        "include": { "src": "adminFacing" },
        "h5Strategy": "emDashOrFirstWord"
      },
      {
        "id": "api",
        "title": "API Changes",
        "include": {
          "anyOf": [
            { "src": "api" },
            { "notTestRelated": true, "matchesRegex": "reroute.apiMethodRe" },
            { "notTestRelated": true, "matchesRegex": "reroute.apiPathRe" }
          ]
        },
        "h5Strategy": "firstWord"
      },
      {
        "id": "page",
        "title": "Page Changes",
        "include": { "src": "page" },
        "h5Strategy": "firstWord"
      },
      {
        "id": "role",
        "title": "Role Changes",
        "include": { "src": "role" },
        "h5Strategy": "firstWord"
      },
      {
        "id": "infra",
        "title": "Infra Changes",
        "include": {
          "anyOf": [
            { "src": "infra" },
            { "startsWithAny": "reroute.infraPrefixWords" },
            { "textContainsAny": "reroute.infraPrefixes" },
            { "matchesRegex": "reroute.slashSkillRe" },
            { "commitFileMatchesPrefix": "reroute.infraPrefixes" },
            { "allCommitFilesUnder": "reroute.infraPrefixes" }
          ]
        },
        "h5Strategy": "infraGroupLabels"
      },
      {
        "id": "doc",
        "title": "Doc Changes",
        "include": { "docsMentionGt": 0 },
        "h5Strategy": "docFilename"
      },
      {
        "id": "db",
        "title": "DB Changes",
        "include": {
          "anyOf": [
            { "src": "db" },
            { "textContainsAny": "reroute.dbPathPrefixes" },
            { "startsWithAny": "reroute.dbBulletPrefixWords" },
            { "matchesRegex": "reroute.dbSqlRe" }
          ]
        },
        "h5Strategy": "dbBulletPrefix"
      },
      {
        "id": "testing",
        "title": "Testing",
        "include": {
          "anyOf": [
            { "src": "test" },
            { "testRelated": true }
          ]
        },
        "h5Strategy": "testingPath",
        "h6": { "onH5": "tests/", "strategy": "testingSubdir" }
      },
      {
        "id": "code",
        "title": "Code Changes",
        "include": {
          "anyOf": [
            { "src": "code" },
            { "matchesRegex": "reroute.codePrefixRe" }
          ]
        },
        "h5Strategy": "codePrefix"
      },
      {
        "id": "workEffort",
        "title": "Work Effort",
        "include": {
          "anyOf": [
            { "src": "workEffort" },
            { "fallthrough": true }
          ]
        },
        "h5Strategy": "tagOrUntagged"
      }
    ]
  },

  "skillSync": {
    "sources": [
      {
        "name": "spt-docs",
        "path": "~/projects/spt-docs",
        "codeRepo": "spt",
        "docsRepo": "spt-docs",
        "replacements": [
          ["../spt", "../Peerloop"],
          ["spt-docs", "peerloop-docs"],
          ["spt", "Peerloop"],
          ["Phase Sequence", "Block Sequence"],
          ["PHASENAME", "BLOCKNAME"],
          ["Phase:", "Block:"],
          ["phase completion", "block completion"],
          ["phase completes", "block completes"],
          ["phase fully", "block fully"],
          ["Phase change", "Block change"],
          ["phase change", "block change"],
          ["Active phase", "Active blocks"],
          ["Focus phase", "Focus block"],
          ["WIP phase", "WIP block"],
          ["Phases completed", "Blocks completed"],
          ["phases", "blocks"],
          ["SOW-01", "Block-08"]
        ]
      }
    ]
  },

  "docsRegistry": {
    "_comment": "Added Conv 132 (DOC-SYNC-STRATEGY Phase 1). Spec: docs/as-designed/doc-sync-strategy.md. Phase 2 migrates sync-gaps.sh, tech-doc-sweep.sh, and /w-sync-docs to read from this.",

    "categories": {
      "generated":  { "description": "Produced entirely by a tool.",              "checkFrequency": "on-source-change" },
      "driftCheck": { "description": "Hand-written with automated audit.",        "checkFrequency": "every-r-end2" },
      "manual":     { "description": "Hand-written, no automated check.",         "checkFrequency": "editorial-only" },
      "archival":   { "description": "Frozen. Edits should be rare and flagged.", "checkFrequency": "never-automated" }
    },

    "groups": [
      {
        "id": "api-docs",
        "category": "driftCheck",
        "pattern": "docs/reference/API-*.md",
        "sourceOfTruth": "../Peerloop/src/pages/api/**/*.ts",
        "checks": ["route-coverage", "phantom-endpoints"],
        "routeMapping": ".claude/scripts/route-mapping.txt",
        "consumers": ["sync-gaps.sh#2", "w-sync-docs#2"]
      },
      {
        "id": "test-docs",
        "category": "driftCheck",
        "pattern": "docs/reference/TEST-*.md",
        "sourceOfTruth": ["../Peerloop/tests/**", "../Peerloop/e2e/**"],
        "sharedBasenames": ["download.test.ts", "index.test.ts", "stats.test.ts", "delete.test.ts", "update.test.ts", "create.test.ts"],
        "checks": ["file-count", "phantom-entries", "path-format"],
        "consumers": ["sync-gaps.sh#4", "w-sync-docs#1"]
      },
      {
        "id": "cli-docs",
        "category": "driftCheck",
        "pattern": "docs/reference/CLI-*.md",
        "sourceOfTruth": "../Peerloop/package.json:scripts",
        "checks": ["script-coverage"],
        "consumers": ["sync-gaps.sh#1", "w-sync-docs#4"]
      },
      {
        "id": "scripts-doc",
        "category": "driftCheck",
        "pattern": "docs/reference/SCRIPTS.md",
        "sourceOfTruth": "../Peerloop/scripts/**/*.{js,ts,sh,mjs}",
        "checks": ["file-coverage"],
        "consumers": ["sync-gaps.sh#3", "w-sync-docs#4"]
      },
      {
        "id": "db-guide",
        "category": "driftCheck",
        "pattern": "docs/reference/DB-GUIDE.md",
        "sourceOfTruth": "../Peerloop/migrations/0001_schema.sql",
        "checks": ["table-coverage", "phantom-tables"],
        "consumers": ["w-sync-docs#3"]
      },
      {
        "id": "vendor-docs",
        "category": "driftCheck",
        "pattern": "docs/reference/{astrojs,stripe,cloudflare,cloudflare-kv,stream,resend,sentry,posthog,bigbluebutton,plugnmeet,reactjs,tailwindcss,cloudinary,charting,google-oauth,auth-libraries,react-big-calendar,react-day-picker}.md",
        "rules": [
          { "codePattern": "webhook.*bbb|video|bigblue|plugnmeet", "topicKeywords": ["bigbluebutton", "bbb", "video", "plugnmeet"] },
          { "codePattern": "stripe|checkout|payment",              "topicKeywords": ["stripe", "payment"] },
          { "codePattern": "src/lib/stream|src/services/stream|getstream|StreamClient", "topicKeywords": ["stream"] },
          { "codePattern": "feed|communit",                          "topicKeywords": ["feeds", "community"] },
          { "codePattern": "email|resend",                          "topicKeywords": ["resend", "email"] },
          { "codePattern": "auth",                                  "topicKeywords": ["auth"] },
          { "codePattern": "booking|availability|calendar",          "topicKeywords": ["booking", "availability"] },
          { "codePattern": "react-big-calendar|BigCalendar",         "topicKeywords": ["react-big-calendar"] },
          { "codePattern": "astro:content|defineCollection|ContentCollectionConfig", "topicKeywords": ["astro"] },
          { "codePattern": "migration",                              "topicKeywords": ["migration"] },
          { "codePattern": "wrangler|lib/db",                        "topicKeywords": ["cloudflare", "d1"] },
          { "codePattern": "pages/api.*review|pages/api.*rating|lib/rating|services/rating", "topicKeywords": ["rating", "feedback"] },
          { "codePattern": "session.*join|session.*room",            "topicKeywords": ["session", "video", "bigbluebutton"] }
        ],
        "consumers": ["tech-doc-sweep.sh"]
      },
      {
        "id": "architecture-active",
        "category": "driftCheck",
        "pattern": "docs/as-designed/*.md",
        "notPattern": "docs/as-designed/_*.md",
        "sourceOfTruth": "../Peerloop/src/**",
        "checks": ["keyword-match"],
        "consumers": ["tech-doc-sweep.sh"]
      },
      {
        "id": "run-001-planning",
        "category": "manual",
        "pattern": "docs/as-designed/run-001/**",
        "note": "Feature decomposition for the current run. Active but no automated check."
      },
      {
        "id": "guides",
        "category": "manual",
        "pattern": "docs/guides/*.md"
      },
      {
        "id": "policy-governance",
        "category": "manual",
        "docs": [
          "docs/POLICIES.md",
          "docs/DECISIONS.md",
          "docs/reference/BEST-PRACTICES.md",
          "docs/reference/DEVELOPMENT-GUIDE.md",
          "DOC-DECISIONS.md",
          "CLAUDE.md"
        ]
      },
      {
        "id": "plan-state",
        "category": "manual",
        "docs": ["PLAN.md", "COMPLETED_PLAN.md", "TIMELINE.md", "CURRENT-BLOCK-PLAN.md"]
      },
      {
        "id": "user-stories",
        "category": "archival",
        "pattern": "docs/requirements/**",
        "note": "Frozen by convention."
      },
      {
        "id": "indexes-archival",
        "category": "archival",
        "docs": ["CONV-INDEX.md", "SESSION-INDEX.md", "docs/DOCS-REORG-MAP.md", "docs/as-designed/orig-pages-map.md"]
      },
      {
        "id": "point-in-time-audits",
        "category": "archival",
        "patterns": [
          "docs/reference/role-audit-*.md",
          "docs/reference/STORY-GAP-ANALYSIS.md",
          "docs/reference/comp-*.md"
        ]
      },
      {
        "id": "legacy-underscore",
        "category": "driftCheck",
        "docs": ["docs/reference/_COMPONENTS.md"],
        "sourceOfTruth": "../Peerloop/src/components/**/*.{tsx,astro}",
        "checks": ["component-coverage"],
        "consumers": ["w-add-client-note"],
        "note": "Only surviving _-prefix doc after Conv 132 retirement sweep. Referenced by /w-add-client-note and CLAUDE.md §Research Reference. Worth a future drift-check migration against src/components/**."
      },
      {
        "id": "skill-generated",
        "category": "generated",
        "docs": [".timecard.md"],
        "generator": ".claude/skills/r-timecard/"
      }
    ]
  }
}
